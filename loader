-- WRAPPER BINDING APIS (Hook functions to named Rows)
-- ============================================================

-- helper to get a state object from page & row name
local function getState(window, pageName, rowName)
    local page = window.States[pageName]
    local state = page and page[rowName]
    if not state then
        warn(string.format("[SysUI] State for row '%s' on page '%s' not found!", tostring(rowName), tostring(pageName)))
    end
    return state
end

-- 1. Bind Toggle
function WindowClass:BindToggle(pageName, rowName, config)
    config = config or {}
    local default = config.Default or false
    local callback = config.Callback or function() end
    
    local state = getState(self, pageName, rowName)
    if state then
        table.insert(state.Callbacks, callback)
        if state.Update then
            state.Update(default, true) -- update silently without firing callbacks on setup
        end
    end
    
    return {
        Set = function(s)
            if state and state.Update then state.Update(s, false) end
        end
    }
end

-- 2. Bind Keybind
function WindowClass:BindKeybind(pageName, rowName, config)
    config = config or {}
    local default = config.Default or Enum.KeyCode.F
    local callback = config.Callback or function() end
    
    local state = getState(self, pageName, rowName)
    local page = self.MainPanel:FindFirstChild(pageName)
    local row = page and page:FindFirstChild(rowName)
    local kbBtn = row and row:FindFirstChild("KeybindButton")
    
    if state and kbBtn then
        state.Key = default
        kbBtn.Text = default == "None" and "[...]" or ("[ " .. formatKeyName(default) .. " ]")
        table.insert(state.Callbacks, callback)
    end
end

-- 3. Bind Slider
function WindowClass:BindSlider(pageName, rowName, config)
    config = config or {}
    local min = config.Min or 0
    local max = config.Max or 100
    local default = config.Default or 50
    local unit = config.Unit or "%"
    local callback = config.Callback or function() end
    
    local state = getState(self, pageName, rowName)
    if state then
        table.insert(state.Callbacks, callback)
        if state.Update then
            state.Update(default, {Min = min, Max = max, Unit = unit})
        end
    end
    
    return {
        Set = function(v)
            if state and state.Update then state.Update(v, {Min = min, Max = max, Unit = unit}) end
        end
    }
end

-- 4. Bind Dropdown
function WindowClass:BindDropdown(pageName, rowName, config)
    config = config or {}
    local options = config.Options or {}
    local default = config.Default or options[1] or ""
    local callback = config.Callback or function() end
    
    local state = getState(self, pageName, rowName)
    if state then
        table.insert(state.Callbacks, callback)
        if state.Populate then state.Populate(options) end
        if state.Update then state.Update(default) end
    end
    
    return {
        Refresh = function(newOpts, newDef)
            if state then
                if state.Populate then state.Populate(newOpts) end
                if newDef and state.Update then state.Update(newDef) end
            end
        end
    }
end

