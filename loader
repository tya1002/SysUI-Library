-- 8. Bind Numeric Spinner
function WindowClass:BindSpinner(pageName, rowName, config)
    config = config or {}
    local min = config.Min or 0
    local max = config.Max or 100
    local default = config.Default or 50
    local step = config.Step or 1
    local callback = config.Callback or function() end
    
    local row = getRow(self, pageName, rowName)
    local cc = row and row:FindFirstChild("CustomControl")
    local input = cc and cc:FindFirstChild("TextBox")
    local minusBtn = cc and cc:FindFirstChild("MinusBtn")
    local plusBtn = cc and cc:FindFirstChild("PlusBtn")
    if not input or not minusBtn or not plusBtn then return end
    
    local value = default
    local function update(newVal)
        value = math.clamp(newVal, min, max)
        input.Text = tostring(value)
        callback(value)
    end
    
    minusBtn.MouseButton1Click:Connect(function() update(value - step) end)
    plusBtn.MouseButton1Click:Connect(function() update(value + step) end)
    input.FocusLost:Connect(function()
        local n = tonumber(input.Text)
        if n then update(n) else input.Text = tostring(value) end
    end)
    
    update(default)
    
    return {
        Set = function(v) update(v) end
    }
end

-- 9. Bind Config Buttons (Load / Save)
function WindowClass:BindConfigActions(config)
    config = config or {}
    local onLoad = config.OnLoad or function() end
    local onSave = config.OnSave or function() end
    
    local settingsPanel = self.MainPanel:FindFirstChild("SettingsPanel")
    local configContainer = settingsPanel and settingsPanel:FindFirstChild("ConfigContainer")
    local loadBtn = configContainer and configContainer:FindFirstChild("LoadConfigBtn")
    local saveBtn = configContainer and configContainer:FindFirstChild("SaveConfigBtn")
    
    local function hook(btn, callback, isSave)
        local stroke = btn:FindFirstChildWhichIsA("UIStroke")
        
        btn.MouseEnter:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 130, 255)}):Play()
            if stroke then TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(0, 220, 255), Transparency = 0.2}):Play() end
        end)
        btn.MouseLeave:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 110, 255)}):Play()
            if stroke then TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(60, 140, 255), Transparency = 0.5}):Play() end
        end)
        
        btn.Activated:Connect(function()
            local targetSize = btn.Size
            local shrinkSize = UDim2.new(0, targetSize.X.Offset - 8, 0, targetSize.Y.Offset - 2)
            
            local shrink = TweenService:Create(btn, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = shrinkSize})
            local restore = TweenService:Create(btn, TweenInfo.new(0.12, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = targetSize})
            
            shrink:Play() task.wait(0.08) restore:Play()
            callback()
            
            SysUI:Notify({
                Title = "Configuration",
                Content = isSave and "Default profile saved successfully!" or "Default profile loaded successfully!",
                Duration = 3.5
            })
        end)
    end
    
    if loadBtn then hook(loadBtn, onLoad, false) end
    if saveBtn then hook(saveBtn, onSave, true) end
end

return SysUI
