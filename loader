-- helper to get a row from page name & row name
local function getRow(window, pageName, rowName)
    local page = window.MainPanel:FindFirstChild(pageName)
    local row = page and page:FindFirstChild(rowName)
    if not row then
        warn(string.format("[SysUI] Row '%s' on page '%s' not found!", tostring(rowName), tostring(pageName)))
    end
    return row
end

-- 1. Bind Toggle
function WindowClass:BindToggle(pageName, rowName, config)
    config = config or {}
    local default = config.Default or false
    local callback = config.Callback or function() end
    
    local row = getRow(self, pageName, rowName)
    local tf = row and row:FindFirstChild("Toggle")
    local sw = tf and tf:FindFirstChild("Switch")
    local knob = sw and sw:FindFirstChild("Knob")
    local sl = tf and tf:FindFirstChild("StatusLabel")
    local clickBtn = sw and (sw:FindFirstChild("ClickButton") or sw)
    if not sw or not knob then return end
    
    local enabled = default
    local function update(state)
        enabled = state
        local kp = enabled and UDim2.new(0, 19, 0.5, 0) or UDim2.new(0, 3, 0.5, 0)
        local bc = enabled and Color3.fromRGB(0, 85, 255) or Color3.fromRGB(20, 26, 46)
        
        TweenService:Create(knob, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = kp}):Play()
        TweenService:Create(sw, TweenInfo.new(0.2), {BackgroundColor3 = bc}):Play()
        if sl then
            sl.Text = enabled and "ON" or "OFF"
            sl.TextColor3 = enabled and Color3.fromRGB(0, 130, 255) or Color3.fromRGB(100, 115, 135)
        end
        callback(enabled)
    end
    
    clickBtn.MouseButton1Click:Connect(function()
        update(not enabled)
        local title = row:FindFirstChild("Title") and row.Title.Text or "Feature"
        SysUI:Notify({Title = title, Content = enabled and "Activated successfully!" or "Deactivated successfully!", Duration = 3})
    end)
    
    update(default)
    
    return {
        Set = function(state) update(state) end
    }
end

-- 2. Bind Keybind
function WindowClass:BindKeybind(pageName, rowName, config)
    config = config or {}
    local default = config.Default or Enum.KeyCode.F
    local callback = config.Callback or function() end
    
    local row = getRow(self, pageName, rowName)
    local kbBtn = row and row:FindFirstChild("KeybindButton")
    if not kbBtn then return end
    
    if not self.KeybindData[pageName] then self.KeybindData[pageName] = {} end
    self.KeybindData[pageName][rowName] = {
        Key = default,
        State = false,
        Callback = callback
    }
    
    kbBtn.Text = default == "None" and "[...]" or ("[ " .. formatKeyName(default) .. " ]")
    local isListening = false
    
    kbBtn.MouseButton1Click:Connect(function()
        if isListening then return end
        isListening = true
        kbBtn.Text = "[...]"
        kbBtn.TextColor3 = Color3.fromRGB(0, 170, 255)
        
        local conn
        conn = UserInputService.InputBegan:Connect(function(input, gp)
            if gp and UserInputService:GetFocusedTextBox() then return end
            local newKey
            if input.UserInputType == Enum.UserInputType.Keyboard then
                newKey = input.KeyCode ~= Enum.KeyCode.Escape and input.KeyCode or "None"
            elseif input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 or input.UserInputType == Enum.UserInputType.MouseButton3 then
                newKey = input.UserInputType
            end
            
            if newKey then
                conn:Disconnect()
                self.KeybindData[pageName][rowName].Key = newKey
                kbBtn.Text = newKey == "None" and "[...]" or ("[ " .. formatKeyName(newKey) .. " ]")
                kbBtn.TextColor3 = Color3.fromRGB(150, 175, 220)
                isListening = false
                
                local title = row:FindFirstChild("Title") and row.Title.Text or "Feature"
                SysUI:Notify({Title = "Keybind Updated", Content = title .. " bound to: " .. formatKeyName(newKey), Duration = 3})
            end
        end)
    end)
    
    kbBtn.MouseEnter:Connect(function()
        if not isListening then TweenService:Create(kbBtn, TweenInfo.new(0.15), {TextColor3 = Color3.fromRGB(255, 255, 255)}):Play() end
    end)
    kbBtn.MouseLeave:Connect(function()
        if not isListening then TweenService:Create(kbBtn, TweenInfo.new(0.15), {TextColor3 = Color3.fromRGB(150, 175, 220)}):Play() end
    end)
end

-- 3. Bind Slider
function WindowClass:BindSlider(pageName, rowName, config)
    config = config or {}
    local min = config.Min or 0
    local max = config.Max or 100
    local default = config.Default or 50
    local unit = config.Unit or ""
    local callback = config.Callback or function() end
    
    local row = getRow(self, pageName, rowName)
    local cc = row and row:FindFirstChild("CustomControl")
    local track = cc and cc:FindFirstChild("Track")
    local fill = track and track:FindFirstChild("Fill")
    local knob = track and track:FindFirstChild("Knob")
    local valLbl = cc and cc:FindFirstChild("ValueLabel")
    if not track or not fill or not knob or not valLbl then return end
    
    local function update(inputObj)
        local ratio = math.clamp((inputObj.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        fill.Size = UDim2.new(ratio, 0, 1, 0)
        knob.Position = UDim2.new(ratio, 0, 0.5, 0)
        local value = min + math.round(ratio * (max - min))
        valLbl.Text = tostring(value) .. unit
        callback(value)
    end
    
    -- Setup initial position
    local initRatio = (default - min) / (max - min)
    fill.Size = UDim2.new(initRatio, 0, 1, 0)
    knob.Position = UDim2.new(initRatio, 0, 0.5, 0)
    valLbl.Text = tostring(default) .. unit
    
    local sliding = false
    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            sliding = true
            update(input)
            
            local mConn, rConn
            mConn = UserInputService.InputChanged:Connect(function(moveInput)
                if sliding and (moveInput.UserInputType == Enum.UserInputType.MouseMovement or moveInput.UserInputType == Enum.UserInputType.Touch) then
                    update(moveInput)
                end
            end)
            
            rConn = UserInputService.InputEnded:Connect(function(releaseInput)
                if releaseInput.UserInputType == Enum.UserInputType.MouseButton1 or releaseInput.UserInputType == Enum.UserInputType.Touch then
                    sliding = false
                    mConn:Disconnect()
                    rConn:Disconnect()
                end
            end)
        end
    end)
    
    return {
        Set = function(v)
            local r = (v - min) / (max - min)
            fill.Size = UDim2.new(r, 0, 1, 0)
            knob.Position = UDim2.new(r, 0, 0.5, 0)
            valLbl.Text = tostring(v) .. unit
            callback(v)
        end
    }
end

-- 4. Bind Dropdown
function WindowClass:BindDropdown(pageName, rowName, config)
    config = config or {}
    local options = config.Options or {}
    local default = config.Default or options[1] or ""
    local callback = config.Callback or function() end
    
    local row = getRow(self, pageName, rowName)
    local cc = row and row:FindFirstChild("CustomControl")
    local header = cc and cc:FindFirstChild("Header")
    local list = cc and cc:FindFirstChild("DropdownList")
    local arrow = header and header:FindFirstChild("Arrow")
    if not header or not list then return end
    
    local openUpwards = (rowName == "Row_E" or rowName == "Row_F" or rowName == "Row_G" or rowName == "Row_H")
    local closedPos = openUpwards and UDim2.new(0, 0, 0, -82) or UDim2.new(0, 0, 1, 4)
    
    header.Text = "   " .. default
    
    local function toggleDropdown()
        list.Visible = not list.Visible
        list.Position = closedPos
        row.ZIndex = list.Visible and 15 or 6
        if arrow then arrow.Text = list.Visible and "▲" or "▼" end
    end
    
    header.MouseButton1Click:Connect(toggleDropdown)
    
    local function populate()
        for _, btn in ipairs(list:GetChildren()) do
            if btn:IsA("TextButton") then btn:Destroy() end
        end
        
        for _, opt in ipairs(options) do
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, 0, 0, 20)
            btn.BackgroundTransparency = 1
            btn.Text = "   " .. opt
            btn.Font = Enum.Font.Gotham
            btn.TextSize = 9
            btn.TextColor3 = Color3.fromRGB(150, 170, 210)
            btn.TextXAlignment = Enum.TextXAlignment.Left
            btn.Parent = list
            
            btn.MouseEnter:Connect(function()
                btn.BackgroundTransparency = 0
                btn.BackgroundColor3 = Color3.fromRGB(20, 45, 110)
                btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            end)
            btn.MouseLeave:Connect(function()
                btn.BackgroundTransparency = 1
                btn.TextColor3 = Color3.fromRGB(150, 170, 210)
            end)
            
            btn.MouseButton1Click:Connect(function()
                header.Text = "   " .. opt
                list.Visible = false
                row.ZIndex = 6
                if arrow then arrow.Text = "▼" end
                callback(opt)
            end)
        end
    end
    
    populate()
    
    return {
        Refresh = function(newOpts, newDef)
            options = newOpts
            populate()
            if newDef then
                header.Text = "   " .. newDef
                callback(newDef)
            end
        end
    }
end

-- 5. Bind Colorpicker
function WindowClass:BindColorpicker(pageName, rowName, config)
    config = config or {}
    local default = config.Default or Color3.fromRGB(0, 110, 255)
    local callback = config.Callback or function() end
    
    local row = getRow(self, pageName, rowName)
    local cc = row and row:FindFirstChild("CustomControl")
    local btn = cc and cc:FindFirstChild("ColorBtn")
    if not btn then return end
    
    btn.BackgroundColor3 = default
    
    local picker = self.ColorPicker
    local satValCanvas = picker:WaitForChild("SatValCanvas")
    local hueSlider = picker:WaitForChild("HueSlider")
    local hexInput = picker:WaitForChild("BottomBar"):WaitForChild("HexInput")
    local applyBtn = picker:WaitForChild("BottomBar"):WaitForChild("ApplyBtn")
    
    local currentH, currentS, currentV = 0, 1, 1
    
    local function updatePickerUI()
        local base = Color3.fromHSV(currentH, 1, 1)
        local selected = Color3.fromHSV(currentH, currentS, currentV)
        satValCanvas.BackgroundColor3 = base
        picker.BottomBar.Preview.BackgroundColor3 = selected
        hexInput.Text = rgbToHex(selected)
        satValCanvas.Pin.Position = UDim2.new(currentS, 0, 1 - currentV, 0)
        hueSlider.Pin.Position = UDim2.new(currentH, 0, 0.5, 0)
        btn.BackgroundColor3 = selected
        callback(selected)
    end
    
    btn.MouseButton1Click:Connect(function()
        local h, s, v = Color3.toHSV(btn.BackgroundColor3)
        currentH, currentS, currentV = h, s, v
        picker.Position = UDim2.new(0, btn.AbsolutePosition.X - 220, 0, btn.AbsolutePosition.Y - 80)
        picker.Visible = true
        updatePickerUI()
        
        -- Tactile
        local shrink = TweenService:Create(btn, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(0, 24, 0, 14)})
        local restore = TweenService:Create(btn, TweenInfo.new(0.12, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, 28, 0, 18)})
        shrink:Play() task.wait(0.08) restore:Play()
    end)
    
    -- Connect Picker dragging to local update (only when this button is active)
    -- We can share the widget. The widget events are hooked globally in `Load` method, but let's handle the specific events for the active picker context:
    -- In order to make it generic, picker's ApplyBtn/HueSlider/SatVal Canvas updates the active window's colorpicker state
    
    return {
        Set = function(color)
            btn.BackgroundColor3 = color
            callback(color)
        end
    }
end

