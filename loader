        local spinInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, 0, true)
        TweenService:Create(introIcon, spinInfo, {Size = UDim2.new(0, 0, 0, 75)}):Play()
        task.wait(0.8)
        
        -- sink
        local sinkInfo = TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        TweenService:Create(introIcon, sinkInfo, {Size = UDim2.new(0, 0, 0, 0), ImageTransparency = 1}):Play()
        TweenService:Create(introGlow, sinkInfo, {Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1}):Play()
        if introGlowStroke then
            TweenService:Create(introGlowStroke, sinkInfo, {Transparency = 1}):Play()
        end
        task.wait(0.5)
        
        introIcon:Destroy()
        introGlow:Destroy()
        
        logoIcon.ImageTransparency = 0
        textLogo.TextTransparency = 0
        
        if onComplete then onComplete() end
    end

    -- ============================================================
    -- LOGIN FLOW EXECUTION
    -- ============================================================
    local function executeLogin(isPremiumKey, isSkip)
        statusLabel.Text = isPremiumKey and "Status : Premium" or "Status : Free"
        currentActiveFrame = "MainFrame"
        
        if not isSkip then
            loginFrame.ClipsDescendants = true
            local info = TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In)
            local tw = TweenService:Create(loginFrame, info, {Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1})
            tw:Play()
            for _, child in ipairs(loginFrame:GetDescendants()) do
                if child:IsA("GuiObject") then
                    if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("TextBox") then
                        TweenService:Create(child, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
                    elseif child:IsA("ImageLabel") then
                        TweenService:Create(child, TweenInfo.new(0.3), {ImageTransparency = 1}):Play()
                    end
                elseif child:IsA("UIStroke") then
                    TweenService:Create(child, TweenInfo.new(0.3), {Transparency = 1}):Play()
                end
            end
            tw.Completed:Wait()
            loginFrame.Visible = false
            
            -- notification
            SysUI:Notify({
                Title = "System Authorization",
                Content = isPremiumKey and "Welcome back! Premium authorized." or "Welcome! Free access authorized.",
                Duration = 3.5
            })
            
            -- play intro
            playIntro(function()
                mainFrame.Size = UDim2.new(0, 0, 0, 0)
                mainFrame.Visible = true
                mainFrame.ClipsDescendants = true
                local openTw = TweenService:Create(mainFrame, TweenInfo.new(0.7, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = originalMainSize})
                openTw:Play()
                openTw.Completed:Wait()
                mainFrame.ClipsDescendants = false
                
                showTab("About")
            end)
        else
            -- skip login
            mainFrame.Size = UDim2.new(0, 0, 0, 0)
            mainFrame.Visible = true
            mainFrame.ClipsDescendants = true
            local openTw = TweenService:Create(mainFrame, TweenInfo.new(0.7, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = originalMainSize})
            openTw:Play()
            openTw.Completed:Wait()
            mainFrame.ClipsDescendants = false
            
            showTab("About")
            SysUI:Notify({
                Title = "System Authorization",
                Content = isPremiumKey and "Welcome back! Premium authorized." or "Welcome! Free access authorized.",
                Duration = 3.5
            })
        end
    end
    
    local keyInput = loginFrame:WaitForChild("KeyInput")
    local loginBtn = loginFrame:WaitForChild("LoginBtn")
    local premiumBtn = loginFrame:WaitForChild("OptionsContainer"):WaitForChild("PremiumBtn")
    local freeBtn = loginFrame:WaitForChild("OptionsContainer"):WaitForChild("FreeBtn")
    
    premiumBtn.Activated:Connect(function() keyInput.Text = "SysHub-Premium-Key" end)
    freeBtn.Activated:Connect(function() keyInput.Text = "SysHub-Free-Key" end)
    
    loginBtn.Activated:Connect(function()
        local k = keyInput.Text
