--[[
    SysUI Library - Premium GUI Wrapper Library (SysHubUI Edition)
    Wraps around the pre-built `SysHubUI` ScreenGui template.
    Allows scripters to load their pre-made GUI design and bind callbacks 
    to rows, buttons, toggles, sliders, dropdowns, inputs, color pickers, and keybinds.
]]

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local SysUI = {
    Notifications = {},
    ActiveWindow = nil
}

-- Lexical Scoping Declarations
local WindowClass = {}
WindowClass.__index = WindowClass

-- Helper: Format Keybind Key Name
local function formatKeyName(input)
    if input == "None" or not input then return "..." end
    if type(input) == "string" then return input end
    local name = tostring(input):gsub("Enum%.KeyCode%.",""):gsub("Enum%.UserInputType%.","")
    if name == "LeftAlt" then return "LAlt" end
    if name == "RightAlt" then return "RAlt" end
    if name == "LeftControl" then return "LCtrl" end
    if name == "RightControl" then return "RCtrl" end
    if name == "LeftShift" then return "LShift" end
    if name == "RightShift" then return "RShift" end
    if name == "MouseButton1" then return "M1" end
    if name == "MouseButton2" then return "M2" end
    if name == "MouseButton3" then return "M3" end
    return name
end

-- Helper: Convert RGB to HEX String
local function rgbToHex(color)
    return string.format("#%02X%02X%02X", math.round(color.R * 255), math.round(color.G * 255), math.round(color.B * 255))
end

-- Helper: Convert HEX String to Color3
local function hexToRgb(hex)
    hex = hex:gsub("#", "")
    if #hex ~= 6 then return Color3.fromRGB(255, 0, 0) end
    local r = tonumber(hex:sub(1, 2), 16) or 255
    local g = tonumber(hex:sub(3, 4), 16) or 0
    local b = tonumber(hex:sub(5, 6), 16) or 0
    return Color3.fromRGB(r, g, b)
end

-- ============================================================
-- TOAST NOTIFICATION SYSTEM
-- ============================================================
function SysUI:Notify(config)
    config = config or {}
    local title = config.Title or "Notification"
    local message = config.Content or ""
    local duration = config.Duration or 3.5
    
    local screenGui = SysUI.ActiveWindow and SysUI.ActiveWindow.Gui
    if not screenGui then return end
    
    local template = screenGui:FindFirstChild("NotificationTemplate")
    if not template then return end
    
    local notif = template:Clone()
    notif.Name = "Notification"
    notif.Title.Text = title
    notif.Message.Text = message
    notif.Visible = true
    notif.Parent = screenGui
    
    table.insert(SysUI.Notifications, 1, notif)
    
    local function reposition()
        for i, card in ipairs(SysUI.Notifications) do
            local targetY = -80 - (i - 1) * 65
            TweenService:Create(card, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = UDim2.new(1, -20, 1, targetY)}):Play()
        end
    end
    
    notif.Position = UDim2.new(1, 300, 1, -80)
    reposition()
    
    TweenService:Create(notif, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(1, -20, 1, -80)}):Play()
    
    task.delay(duration, function()
        local idx = table.find(SysUI.Notifications, notif)
        if idx then table.remove(SysUI.Notifications, idx) end
        
        local slideOut = TweenService:Create(notif, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Position = UDim2.new(1, 300, notif.Position.Y.Scale, notif.Position.Y.Offset)})
        slideOut:Play()
        reposition()
        
        slideOut.Completed:Wait()
        notif:Destroy()
    end)
end

-- ============================================================
-- DRAGGABLE & RESIZABLE HANDLER
-- ============================================================
local function setupDraggableAndResizable(frame, dragHandles, minSize, maxSize, onResizeEnd)
    local dragging = false
    local dragInput, dragStart, startPos
    
    for _, handle in ipairs(dragHandles) do
        handle.Active = true
        handle.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                dragStart = input.Position
                startPos = frame.Position
                
                local conn
                conn = input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        dragging = false
                        conn:Disconnect()
                    end
                end)
            end
        end)
        
        handle.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                dragInput = input
            end
        end)
    end
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input == dragInput then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
    
    local resizeGrip = frame:FindFirstChild("ResizeGrip")
    if resizeGrip then
        local resizing = false
        local startSize, startFramePos, resizeStart
        
        resizeGrip.MouseEnter:Connect(function()
            TweenService:Create(resizeGrip, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(0, 220, 255), TextTransparency = 0.2}):Play()
        end)
        resizeGrip.MouseLeave:Connect(function()
            TweenService:Create(resizeGrip, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(0, 180, 255), TextTransparency = 0.4}):Play()
        end)
        
        resizeGrip.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                resizing = true
                resizeStart = input.Position
                startSize = frame.AbsoluteSize
                startFramePos = frame.Position
                
                local conn
                conn = input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        resizing = false
                        conn:Disconnect()
                        if onResizeEnd then onResizeEnd(frame.Size) end
                    end
                end)
            end
        end)
        
        UserInputService.InputChanged:Connect(function(input)
            if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local delta = input.Position - resizeStart
                local newW = math.clamp(startSize.X + delta.X, minSize.X, maxSize.X)
                local newH = math.clamp(startSize.Y + delta.Y, minSize.Y, maxSize.Y)
                
                local changeW = newW - startSize.X
                local changeH = newH - startSize.Y
                
                frame.Size = UDim2.new(0, newW, 0, newH)
                frame.Position = UDim2.new(
                    startFramePos.X.Scale, startFramePos.X.Offset + changeW * 0.5,
                    startFramePos.Y.Scale, startFramePos.Y.Offset + changeH * 0.5
                )
            end
        end)
    end
end

-- ============================================================
-- LOAD GUI TEMPLATE & INITIALIZE CORE BEHAVIORS
-- ============================================================
function SysUI:Load(config)
    config = config or {}
    local authKey = config.Key
    
    -- Destroy existing clone if any
    local existing = PlayerGui:FindFirstChild("SysHubUI_Loaded")
    if existing then existing:Destroy() end
    
    -- Load the template: First try local sources, then fallback to Roblox Cloud Asset (for executor)
    local template
    local localSource
    pcall(function()
        if script and typeof(script) == "Instance" then
            localSource = script:FindFirstChild("SysHubUI")
        end
    end)
    if not localSource then
        pcall(function()
            localSource = game:GetService("StarterGui"):FindFirstChild("SysHubUI")
        end)
    end
    
    if localSource then
        template = localSource:Clone()
    else
        local success, asset = pcall(function()
            return game:GetObjects("rbxassetid://89324887405137")[1]
        end)
        if success and asset then
            template = asset
        end
    end
    
    assert(template, "SysHubUI ScreenGui template not found locally or in Roblox Cloud (Asset ID: 89324887405137)!")
    
    local gui = template
    gui.Name = "SysHubUI_Loaded"
    gui.ResetOnSpawn = false
    
    -- Destroy the original SysHubUILogic to prevent conflicts with the library
    local logic = gui:FindFirstChild("SysHubUILogic")
    if logic then logic:Destroy() end
    
    local mainFrame = gui:WaitForChild("MainFrame")
    local loginFrame = gui:WaitForChild("LoginFrame")
    local sidebar = mainFrame:WaitForChild("Sidebar")
    local sidebarScroll = sidebar:WaitForChild("SidebarScroll")
    local mainPanel = mainFrame:WaitForChild("MainPanel")
    local minimizedWidget = gui:WaitForChild("MinimizedWidget")
    local colorPickerWidget = gui:WaitForChild("ColorPickerWidget")
    
    local profileCard = sidebar:WaitForChild("ProfileCard")
    local displayNameLabel = profileCard:WaitForChild("DisplayName")
    local statusLabel = profileCard:WaitForChild("Status")
    
    local header = mainPanel:WaitForChild("Header")
    local titleLabel = header:WaitForChild("Title")
    local subtitleLabel = header:WaitForChild("Subtitle")
    local searchBoxFrame = header:WaitForChild("SearchBox")
    local searchBox = searchBoxFrame:WaitForChild("TextBox")
    
    local aboutPanel = mainPanel:WaitForChild("AboutPanel")
    local settingsPanel = mainPanel:WaitForChild("SettingsPanel")
    
    local btnAbout = sidebarScroll:WaitForChild("Btn_About")
    local btnSettings = sidebarScroll:WaitForChild("Btn_Settings")
    
    -- Local variables for state
    local currentActiveFrame = "LoginFrame"
    local originalLoginSize = loginFrame.Size
    local originalMainSize = mainFrame.Size
    local isBindingAnyKey = false
    
    -- Instantiate metatable object
    local Window = setmetatable({
        Gui = gui,
        Main = mainFrame,
        MainPanel = mainPanel,
        ColorPicker = colorPickerWidget,
        States = {} -- Dynamically tracks all toggle, slider, keybind values and callbacks
    }, WindowClass)
    
    -- Display Name Setup (kept as name only per user request)
    displayNameLabel.Text = LocalPlayer.DisplayName
    
    -- Ensure bulatan glow di belakang logo disembunyikan
    local logoGroup = sidebar:WaitForChild("LogoGroup")
    local logoCircleGlow = logoGroup:WaitForChild("LogoCircleGlow")
    if logoCircleGlow then
        logoCircleGlow.BackgroundTransparency = 1
        local stroke = logoCircleGlow:FindFirstChildWhichIsA("UIStroke")
        if stroke then stroke.Transparency = 1 end
    end
    
    -- Setup Windows Drag & Resize
    setupDraggableAndResizable(loginFrame, {loginFrame:WaitForChild("Background")}, Vector2.new(300, 320), Vector2.new(600, 620), function(s) originalLoginSize = s end)
    setupDraggableAndResizable(mainFrame, {sidebar, header}, Vector2.new(500, 350), Vector2.new(1000, 700), function(s) originalMainSize = s end)
    
    -- ============================================================
    -- TAB NAVIGATION SYSTEM
    -- ============================================================
    local function showTab(tabName, groupNum, itemLetter)
        for _, page in ipairs(mainPanel:GetChildren()) do
            if (page:IsA("ScrollingFrame") and page.Name:match("^Page_")) or page.Name == "SettingsPanel" then
                page.Visible = false
            end
        end
        
        if tabName == "About" then
            aboutPanel.Visible = true
            searchBoxFrame.Visible = false
            titleLabel.Text = "Tentang SysHub"
            subtitleLabel.Text = "Premium"
        elseif tabName == "Settings" then
            aboutPanel.Visible = false
            settingsPanel.Visible = true
            searchBoxFrame.Visible = false
            titleLabel.Text = "Settings"
            subtitleLabel.Text = "Visual & UI"
        else
            aboutPanel.Visible = false
            searchBoxFrame.Visible = true
            local pageName = "Page_" .. tostring(groupNum) .. "_" .. tostring(itemLetter)
            local targetPage = mainPanel:FindFirstChild(pageName)
            if targetPage then targetPage.Visible = true end
            titleLabel.Text = "Menu " .. groupNum .. "-" .. itemLetter
            subtitleLabel.Text = "SubMenu " .. groupNum .. "-" .. itemLetter
        end
    end
    
    -- Tab Buttons
    btnAbout.Activated:Connect(function() showTab("About") end)
    btnSettings.Activated:Connect(function() showTab("Settings") end)
    
    -- Hover Transitions for About & Settings
    for _, btn in ipairs({btnAbout, btnSettings}) do
        local lbl = btn:FindFirstChild("Label")
        local stroke = btn:FindFirstChildWhichIsA("UIStroke")
        btn.MouseEnter:Connect(function()
            btn.BackgroundTransparency = 0
            btn.BackgroundColor3 = Color3.fromRGB(20, 50, 130)
            if lbl then lbl.TextColor3 = Color3.fromRGB(255, 255, 255) end
            if stroke then TweenService:Create(stroke, TweenInfo.new(0.15), {Color = Color3.fromRGB(60, 120, 255), Transparency = 0.3}):Play() end
        end)
        btn.MouseLeave:Connect(function()
            btn.BackgroundTransparency = 0.2
            btn.BackgroundColor3 = Color3.fromRGB(10, 18, 45)
            if lbl then lbl.TextColor3 = Color3.fromRGB(140, 165, 210) end
            if stroke then TweenService:Create(stroke, TweenInfo.new(0.15), {Color = Color3.fromRGB(30, 60, 140), Transparency = 0.65}):Play() end
        end)
    end
    
    -- Dropdown Group Menus
    local function setupSidebarGroup(group)
        local h = group:FindFirstChild("Header")
        local sub = group:FindFirstChild("SubItems")
        local arr = h and h:FindFirstChild("Arrow")
        if not h or not sub then return end
        
        local open = false
        h.MouseButton1Click:Connect(function()
            open = not open
            local info = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
            local targetSubH = open and 90 or 0
            local targetGroupH = 30 + targetSubH
            
            TweenService:Create(sub, info, {Size = UDim2.new(1, 0, 0, targetSubH)}):Play()
            TweenService:Create(group, info, {Size = UDim2.new(1, 0, 0, targetGroupH)}):Play()
            if arr then
                arr.Text = open and "▼" or "►"
                TweenService:Create(arr, info, {TextColor3 = open and Color3.fromRGB(80, 160, 255) or Color3.fromRGB(100, 130, 200)}):Play()
            end
        end)
        
        for _, item in ipairs(sub:GetChildren()) do
            if item:IsA("TextButton") then
                local lbl = item:FindFirstChild("Label")
                local stroke = item:FindFirstChildWhichIsA("UIStroke")
                item.MouseEnter:Connect(function()
                    item.BackgroundTransparency = 0
                    item.BackgroundColor3 = Color3.fromRGB(20, 50, 130)
                    if lbl then lbl.TextColor3 = Color3.fromRGB(255, 255, 255) end
                    if stroke then TweenService:Create(stroke, TweenInfo.new(0.15), {Color = Color3.fromRGB(60, 120, 255), Transparency = 0.3}):Play() end
                end)
                item.MouseLeave:Connect(function()
                    item.BackgroundTransparency = 0.2
                    item.BackgroundColor3 = Color3.fromRGB(10, 18, 45)
                    if lbl then lbl.TextColor3 = Color3.fromRGB(140, 165, 210) end
                    if stroke then TweenService:Create(stroke, TweenInfo.new(0.15), {Color = Color3.fromRGB(30, 60, 140), Transparency = 0.65}):Play() end
                end)
                
                item.Activated:Connect(function()
                    local gNum = group.Name:match("^Group_(%d+)") or "1"
                    local iLetter = item.Name:match("^Item_(%a+)") or "A"
                    showTab("Keybinds", gNum, iLetter)
                end)
            end
        end
    end
    
    for _, g in ipairs(sidebarScroll:GetChildren()) do
        if g:IsA("Frame") and g.Name:match("^Group_") then
            setupSidebarGroup(g)
        end
    end
    
    -- ============================================================
    -- LOGO 3D SPIN ANIMATION ON MINIMIZE
    -- ============================================================
    local spinConn
    local function startSpin()
        if spinConn then spinConn:Disconnect() end
        local rSpeed, sSpeed, elapsed = 10, 0.2, 0
        spinConn = RunService.RenderStepped:Connect(function(dt)
            minimizedWidget.Glow.Rotation = (minimizedWidget.Glow.Rotation + rSpeed * dt) % 360
            elapsed = elapsed + dt
            local sx = math.cos(elapsed * sSpeed * math.pi)
            minimizedWidget.Icon.Size = UDim2.new(0, math.abs(sx) * 80, 0, 75)
        end)
    end
    
    local function stopSpin()
        if spinConn then spinConn:Disconnect() spinConn = nil end
        minimizedWidget.Icon.Size = UDim2.new(0, 80, 0, 75)
        minimizedWidget.Glow.Rotation = 0
    end
    
    -- Minimize / Restore Handlers
    local function animateMinimize()
        local info = TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        if currentActiveFrame == "LoginFrame" then
            loginFrame.ClipsDescendants = true
            TweenService:Create(loginFrame, info, {Size = UDim2.new(0, originalLoginSize.X.Offset, 0, 0)}):Play()
            task.wait(0.5)
            loginFrame.Visible = false
        else
            mainFrame.ClipsDescendants = true
            TweenService:Create(mainFrame, info, {Size = UDim2.new(0, originalMainSize.X.Offset, 0, 0)}):Play()
            task.wait(0.5)
            mainFrame.Visible = false
        end
        minimizedWidget.Visible = true
        startSpin()
    end
    
    local function animateRestore()
        stopSpin()
        minimizedWidget.Visible = false
        local info = TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        
        if currentActiveFrame == "LoginFrame" then
            loginFrame.Size = UDim2.new(0, originalLoginSize.X.Offset, 0, 0)
            loginFrame.Visible = true
            loginFrame.ClipsDescendants = true
            local tw = TweenService:Create(loginFrame, info, {Size = originalLoginSize})
            tw:Play()
            task.spawn(function() tw.Completed:Wait() loginFrame.ClipsDescendants = false end)
        else
            mainFrame.Size = UDim2.new(0, originalMainSize.X.Offset, 0, 0)
            mainFrame.Visible = true
            mainFrame.ClipsDescendants = true
            local tw = TweenService:Create(mainFrame, info, {Size = originalMainSize})
            tw:Play()
            task.spawn(function() tw.Completed:Wait() mainFrame.ClipsDescendants = false end)
        end
    end
    
    minimizedWidget.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            local startPos = input.Position
            local conn
            conn = input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    conn:Disconnect()
                    if (input.Position - startPos).Magnitude < 6 then
                        animateRestore()
                    end
                end
            end)
        end
    end)
    
    setupDraggableAndResizable(minimizedWidget, {minimizedWidget}, Vector2.new(40,40), Vector2.new(500,500))
    
    -- Window Control Clicks
    local mainMin = mainFrame:WaitForChild("WindowControls"):WaitForChild("MinimizeBtn")
    local mainClose = mainFrame:WaitForChild("WindowControls"):WaitForChild("CloseBtn")
    local loginMin = loginFrame:WaitForChild("WindowControls"):WaitForChild("MinimizeBtn")
    local loginClose = loginFrame:WaitForChild("WindowControls"):WaitForChild("CloseBtn")
    
    mainMin.MouseButton1Click:Connect(animateMinimize)
    loginMin.MouseButton1Click:Connect(animateMinimize)
    mainClose.MouseButton1Click:Connect(function() gui:Destroy() end)
    loginClose.MouseButton1Click:Connect(function() gui:Destroy() end)
    
    -- Control Buttons Hover Transitions
    for _, btn in ipairs({mainMin, mainClose, loginMin, loginClose}) do
        local icon = btn:FindFirstChild("Icon") or btn:FindFirstChild("IconText")
        local stroke = btn:FindFirstChildWhichIsA("UIStroke")
        btn.MouseEnter:Connect(function()
            if btn.Name == "CloseBtn" then
                TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(180, 40, 40)}):Play()
                if stroke then TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(255, 100, 100), Transparency = 0.2}):Play() end
                if icon and icon:IsA("ImageLabel") then TweenService:Create(icon, TweenInfo.new(0.2), {ImageColor3 = Color3.fromRGB(255, 255, 255)}):Play() end
            else
                TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(40, 60, 110)}):Play()
                if stroke then TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(80, 120, 255), Transparency = 0.2}):Play() end
                if icon and icon:IsA("ImageLabel") then TweenService:Create(icon, TweenInfo.new(0.2), {ImageColor3 = Color3.fromRGB(255, 255, 255)}):Play() end
            end
        end)
        btn.MouseLeave:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(20, 26, 46)}):Play()
            if stroke then TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(30, 42, 75), Transparency = 0.5}):Play() end
            if icon and icon:IsA("ImageLabel") then TweenService:Create(icon, TweenInfo.new(0.2), {ImageColor3 = Color3.fromRGB(150, 170, 210)}):Play() end
        end)
    end
    
    -- ============================================================
    -- INTRO ANIMATION PLAYBACK
    -- ============================================================
    local logoGroup = sidebar:WaitForChild("LogoGroup")
    local logoIcon = logoGroup:WaitForChild("Icon")
    local textLogo = logoGroup:WaitForChild("Text")
    local logoCircleGlow = logoGroup:WaitForChild("LogoCircleGlow")
    
    local function playIntro(onComplete)
        loginFrame.Visible = false
        mainFrame.Visible = false
        minimizedWidget.Visible = false
        
        logoIcon.ImageTransparency = 1
        if logoIcon:FindFirstChild("LightSweep") then logoIcon.LightSweep.ImageTransparency = 1 end
        textLogo.TextTransparency = 1
        
        -- 1. Cloned Icon (Size: 80x75)
        local introIcon = logoIcon:Clone()
        introIcon.Name = "IntroIcon"
        introIcon.Size = UDim2.new(0, 80, 0, 75)
        introIcon.Position = UDim2.new(0.5, 0, 0.5, 0)
        introIcon.AnchorPoint = Vector2.new(0.5, 0.5)
        introIcon.ZIndex = 100
        introIcon.ImageTransparency = 1
        introIcon.Parent = gui
        
        -- 2. Cloned Glow Circle (Size: 100x100)
        local introGlow = logoCircleGlow:Clone()
        introGlow.Name = "IntroGlow"
        introGlow.Size = UDim2.new(0, 100, 0, 100)
        introGlow.Position = UDim2.new(0.5, 0, 0.5, 0)
        introGlow.AnchorPoint = Vector2.new(0.5, 0.5)
        introGlow.ZIndex = 99
        introGlow.BackgroundTransparency = 1
        local introGlowStroke = introGlow:FindFirstChildWhichIsA("UIStroke")
        if introGlowStroke then introGlowStroke.Transparency = 1 end
        introGlow.Parent = gui
        
        local lightSweep = introIcon:FindFirstChild("LightSweep")
        if lightSweep then
            lightSweep.Position = UDim2.new(-2, 0, -0.5, 0)
            lightSweep.ImageTransparency = 1
        end
        
        -- 3. Fade In
        local infoFade = TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        TweenService:Create(introIcon, infoFade, {ImageTransparency = 0}):Play()
        TweenService:Create(introGlow, infoFade, {BackgroundTransparency = 0.7}):Play()
        if introGlowStroke then
            TweenService:Create(introGlowStroke, infoFade, {Transparency = 0.4}):Play()
        end
        task.wait(0.6)
        
        -- 4. Light Sweep
        if lightSweep then
            lightSweep.ImageTransparency = 0.3
            local sweepInfo = TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut)
            TweenService:Create(lightSweep, sweepInfo, {Position = UDim2.new(1.5, 0, -0.5, 0)}):Play()
            task.wait(0.8)
            TweenService:Create(lightSweep, TweenInfo.new(0.2), {ImageTransparency = 1}):Play()
        end
        
        -- 5. Spin Horizontally
        local spinInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, 0, true)
        TweenService:Create(introIcon, spinInfo, {Size = UDim2.new(0, 0, 0, 75)}):Play()
        task.wait(0.8)
        
        -- 6. Sink & Fade Out
        local sinkInfo = TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        TweenService:Create(introIcon, sinkInfo, {Size = UDim2.new(0, 0, 0, 0), ImageTransparency = 1}):Play()
        TweenService:Create(introGlow, sinkInfo, {Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1}):Play()
        if introGlowStroke then
            TweenService:Create(introGlowStroke, sinkInfo, {Transparency = 1}):Play()
        end
        task.wait(0.5)
        
        introIcon:Destroy()
        introGlow:Destroy()
        
        logoIcon.ImageTransparency = 0
        textLogo.TextTransparency = 0
        
        if onComplete then onComplete() end
    end

    -- ============================================================
    -- LOGIN FLOW EXECUTION
    -- ============================================================
    local function executeLogin(isPremiumKey, isSkip)
        statusLabel.Text = isPremiumKey and "Status : Premium" or "Status : Free"
        currentActiveFrame = "MainFrame"
        
        if not isSkip then
            loginFrame.ClipsDescendants = true
            local info = TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In)
            local tw = TweenService:Create(loginFrame, info, {Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1})
            tw:Play()
            for _, child in ipairs(loginFrame:GetDescendants()) do
                if child:IsA("GuiObject") then
                    if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("TextBox") then
                        TweenService:Create(child, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
                    elseif child:IsA("ImageLabel") then
                        TweenService:Create(child, TweenInfo.new(0.3), {ImageTransparency = 1}):Play()
                    end
                elseif child:IsA("UIStroke") then
                    TweenService:Create(child, TweenInfo.new(0.3), {Transparency = 1}):Play()
                end
            end
            tw.Completed:Wait()
            loginFrame.Visible = false
            
            -- Show successful login notification
            SysUI:Notify({
                Title = "System Authorization",
                Content = isPremiumKey and "Welcome back! Premium authorized." or "Welcome! Free access authorized.",
                Duration = 3.5
            })
            
            -- Play Intro Animation before MainFrame slides open
            playIntro(function()
                mainFrame.Size = UDim2.new(0, 0, 0, 0)
                mainFrame.Visible = true
                mainFrame.ClipsDescendants = true
                local openTw = TweenService:Create(mainFrame, TweenInfo.new(0.7, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = originalMainSize})
                openTw:Play()
                openTw.Completed:Wait()
                mainFrame.ClipsDescendants = false
                
                showTab("About")
            end)
        else
            -- Skip login (direct open MainFrame)
            mainFrame.Size = UDim2.new(0, 0, 0, 0)
            mainFrame.Visible = true
            mainFrame.ClipsDescendants = true
            local openTw = TweenService:Create(mainFrame, TweenInfo.new(0.7, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = originalMainSize})
            openTw:Play()
            openTw.Completed:Wait()
            mainFrame.ClipsDescendants = false
            
            showTab("About")
            SysUI:Notify({
                Title = "System Authorization",
                Content = isPremiumKey and "Welcome back! Premium authorized." or "Welcome! Free access authorized.",
                Duration = 3.5
            })
        end
    end
    
    local keyInput = loginFrame:WaitForChild("KeyInput")
    local loginBtn = loginFrame:WaitForChild("LoginBtn")
    local premiumBtn = loginFrame:WaitForChild("OptionsContainer"):WaitForChild("PremiumBtn")
    local freeBtn = loginFrame:WaitForChild("OptionsContainer"):WaitForChild("FreeBtn")
    
    premiumBtn.Activated:Connect(function() keyInput.Text = "SysHub-Premium-Key" end)
    freeBtn.Activated:Connect(function() keyInput.Text = "SysHub-Free-Key" end)
    
    loginBtn.Activated:Connect(function()
        local k = keyInput.Text
        if k == "" then
            -- Shake
            local originalPos = loginFrame.Position
            for i = 1, 6 do
                local offset = (i % 2 == 0) and 8 or -8
                loginFrame.Position = UDim2.new(originalPos.X.Scale, originalPos.X.Offset + offset, originalPos.Y.Scale, originalPos.Y.Offset)
                task.wait(0.04)
            end
            loginFrame.Position = originalPos
            return
        end
        
        local isPremium = not k:lower():find("free")
        executeLogin(isPremium, false)
    end)
    
    -- Auto-skip login if authorization key is pre-set
    if authKey then
        task.spawn(function()
            task.wait(0.1)
            playIntro(function()
                executeLogin(not authKey:lower():find("free"), true)
            end)
        end)
    else
        -- Start sequence: Play intro first, then show LoginFrame
        task.spawn(function()
            task.wait(0.1)
            playIntro(function()
                loginFrame.Size = UDim2.new(0, originalLoginSize.X.Offset, 0, 0)
                loginFrame.Visible = true
                loginFrame.ClipsDescendants = true
                local openTw = TweenService:Create(loginFrame, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = originalLoginSize})
                openTw:Play()
                openTw.Completed:Wait()
                loginFrame.ClipsDescendants = false
            end)
        end)
    end
    
    -- Discord Button
    local dcBtn = aboutPanel:WaitForChild("AboutScroll"):WaitForChild("DiscordContainer"):WaitForChild("DiscordBtn")
    dcBtn.Activated:Connect(function()
        if setclipboard then pcall(function() setclipboard("https://discord.gg/syshub") end) end
        SysUI:Notify({Title = "Discord Link", Content = "Discord link copied to clipboard!", Duration = 3})
    end)
    
    -- Search filtering
    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        local q = searchBox.Text:lower()
        for _, page in ipairs(mainPanel:GetChildren()) do
            if page:IsA("ScrollingFrame") and page.Name:match("^Page_") then
                for _, r in ipairs(page:GetChildren()) do
                    if r:IsA("Frame") and r.Name:match("^Row_") then
                        local t = r:FindFirstChild("Title") and r.Title.Text or ""
                        r.Visible = q == "" or t:lower():find(q, 1, true) ~= nil
                    end
                end
            end
        end
    end)
    
    -- ============================================================
    -- DYNAMIC AUTO-INITIALIZATION SYSTEM FOR ALL ROWS
    -- ============================================================
    local function initRowInteractive(row, pageName, rowName)
        Window.States[pageName][rowName] = {
            Value = nil,
            Callbacks = {},
            Key = "None"
        }
        
        -- Hook hover animations
        local stroke = row:FindFirstChild("UIStroke")
        row.MouseEnter:Connect(function()
            if stroke then TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(30, 60, 110), Thickness = 1.2}):Play() end
        end)
        row.MouseLeave:Connect(function()
            if stroke and not (Window.States[pageName][rowName].Type == "Toggle" and Window.States[pageName][rowName].Value) then
                TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(20, 28, 48), Thickness = 1}):Play()
            end
        end)
        
        -- 1. Hook Toggle Switch if present
        local tf = row:FindFirstChild("Toggle")
        local sw = tf and tf:FindFirstChild("Switch")
        local knob = sw and sw:FindFirstChild("Knob")
        local sl = tf and tf:FindFirstChild("StatusLabel")
        local clickBtn = sw and (sw:FindFirstChild("ClickButton") or sw)
        
        if sw and knob then
            Window.States[pageName][rowName].Type = "Toggle"
            Window.States[pageName][rowName].Value = false
            
            local function updateToggle(state, silent)
                Window.States[pageName][rowName].Value = state
                local kp = state and UDim2.new(0, 19, 0.5, 0) or UDim2.new(0, 3, 0.5, 0)
                local bc = state and Color3.fromRGB(0, 85, 255) or Color3.fromRGB(20, 26, 46)
                
                TweenService:Create(knob, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = kp}):Play()
                TweenService:Create(sw, TweenInfo.new(0.2), {BackgroundColor3 = bc}):Play()
                if sl then
                    sl.Text = state and "ON" or "OFF"
                    sl.TextColor3 = state and Color3.fromRGB(0, 130, 255) or Color3.fromRGB(100, 115, 135)
                end
                
                -- Trigger callbacks
                if not silent then
                    for _, cb in ipairs(Window.States[pageName][rowName].Callbacks) do
                        pcall(cb, state)
                    end
                end
            end
            
            clickBtn.MouseButton1Click:Connect(function()
                local newState = not Window.States[pageName][rowName].Value
                updateToggle(newState, false)
                local title = row:FindFirstChild("Title") and row.Title.Text or "Feature"
                SysUI:Notify({Title = title, Content = newState and "Activated successfully!" or "Deactivated successfully!", Duration = 3})
            end)
            
            Window.States[pageName][rowName].Update = updateToggle
            updateToggle(false, true)
        end
        
        -- 2. Hook Keybind Button if present
        local kb = row:FindFirstChild("KeybindButton")
        if kb then
            kb.Text = "[...]"
            local isListening = false
            kb.MouseButton1Click:Connect(function()
                if isListening then return end
                isListening = true
                isBindingAnyKey = true
                kb.Text = "[...]"
                kb.TextColor3 = Color3.fromRGB(0, 170, 255)
                
                local conn
                conn = UserInputService.InputBegan:Connect(function(inputEvent, gp)
                    if gp and UserInputService:GetFocusedTextBox() then return end
                    local newKey
                    if inputEvent.UserInputType == Enum.UserInputType.Keyboard then
                        newKey = inputEvent.KeyCode ~= Enum.KeyCode.Escape and inputEvent.KeyCode or "None"
                    elseif inputEvent.UserInputType == Enum.UserInputType.MouseButton1 or inputEvent.UserInputType == Enum.UserInputType.MouseButton2 or inputEvent.UserInputType == Enum.UserInputType.MouseButton3 then
                        newKey = inputEvent.UserInputType
                    end
                    
                    if newKey then
                        conn:Disconnect()
                        Window.States[pageName][rowName].Key = newKey
                        kb.Text = (newKey == "None") and "[...]" or ("[ " .. formatKeyName(newKey) .. " ]")
                        kb.TextColor3 = Color3.fromRGB(150, 175, 220)
                        isListening = false
                        task.wait()
                        isBindingAnyKey = false
                        
                        local titleText = row:FindFirstChild("Title") and row.Title.Text or "Feature"
                        SysUI:Notify({Title = "Keybind Updated", Content = titleText .. " bound to: " .. formatKeyName(newKey), Duration = 3.5})
                    end
                end)
            end)
            
            kb.MouseEnter:Connect(function()
                if not isListening then TweenService:Create(kb, TweenInfo.new(0.15), {TextColor3 = Color3.fromRGB(255, 255, 255)}):Play() end
            end)
            kb.MouseLeave:Connect(function()
                if not isListening then TweenService:Create(kb, TweenInfo.new(0.15), {TextColor3 = Color3.fromRGB(150, 175, 220)}):Play() end
            end)
        end
        
        -- 3. Custom Control Helpers
        local cc = row:FindFirstChild("CustomControl")
        if cc then
            -- A. Dropdown List
            local list = cc:FindFirstChild("DropdownList")
            local dHeader = cc:FindFirstChild("Header")
            local dArrow = dHeader and dHeader:FindFirstChild("Arrow")
            if dHeader and list then
                Window.States[pageName][rowName].Type = "Dropdown"
                local openUpwards = (rowName == "Row_E" or rowName == "Row_F" or rowName == "Row_G" or rowName == "Row_H")
                local closedPos = openUpwards and UDim2.new(0, 0, 0, -82) or UDim2.new(0, 0, 1, 4)
                
                dHeader.Text = "   Select..."
                dHeader.MouseButton1Click:Connect(function()
                    list.Visible = not list.Visible
                    list.Position = closedPos
                    row.ZIndex = list.Visible and 15 or 6
                    if dArrow then dArrow.Text = list.Visible and "▲" or "▼" end
                end)
                
                local function setupListBtn(btn)
                    btn.MouseEnter:Connect(function()
                        btn.BackgroundTransparency = 0
                        btn.BackgroundColor3 = Color3.fromRGB(20, 45, 110)
                        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
                    end)
                    btn.MouseLeave:Connect(function()
                        btn.BackgroundTransparency = 1
                        btn.TextColor3 = Color3.fromRGB(150, 170, 210)
                    end)
                    btn.MouseButton1Click:Connect(function()
                        local selectedVal = btn.Text:gsub("^%s+", "")
                        dHeader.Text = "   " .. selectedVal
                        list.Visible = false
                        row.ZIndex = 6
                        if dArrow then dArrow.Text = "▼" end
                        
                        Window.States[pageName][rowName].Value = selectedVal
                        for _, cb in ipairs(Window.States[pageName][rowName].Callbacks) do
                            pcall(cb, selectedVal)
                        end
                    end)
                end
                
                for _, btn in ipairs(list:GetChildren()) do
                    if btn:IsA("TextButton") then setupListBtn(btn) end
                end
                
                Window.States[pageName][rowName].Populate = function(options)
                    for _, old in ipairs(list:GetChildren()) do
                        if old:IsA("TextButton") then old:Destroy() end
                    end
                    for _, opt in ipairs(options) do
                        local btn = Instance.new("TextButton")
                        btn.Size = UDim2.new(1, 0, 0, 20)
                        btn.BackgroundTransparency = 1
                        btn.Text = "   " .. opt
                        btn.Font = Enum.Font.Gotham
                        btn.TextSize = 9
                        btn.TextColor3 = Color3.fromRGB(150, 170, 210)
                        btn.TextXAlignment = Enum.TextXAlignment.Left
                        btn.Parent = list
                        setupListBtn(btn)
                    end
                end
                
                Window.States[pageName][rowName].Update = function(val)
                    dHeader.Text = "   " .. tostring(val)
                    Window.States[pageName][rowName].Value = val
                    for _, cb in ipairs(Window.States[pageName][rowName].Callbacks) do
                        pcall(cb, val)
                    end
                end
            end
            
            -- B. Spinner Control
            local minusBtn = cc:FindFirstChild("MinusBtn")
            local plusBtn = cc:FindFirstChild("PlusBtn")
            local spinInput = cc:FindFirstChild("TextBox")
            if minusBtn and plusBtn and spinInput then
                Window.States[pageName][rowName].Type = "Spinner"
                local value = 50
                local spinMin, spinMax, spinStep = 0, 100, 1
                
                local function updateSpinner(newVal, silent)
                    value = math.clamp(newVal, spinMin, spinMax)
                    spinInput.Text = tostring(value)
                    Window.States[pageName][rowName].Value = value
                    if not silent then
                        for _, cb in ipairs(Window.States[pageName][rowName].Callbacks) do
                            pcall(cb, value)
                        end
                    end
                end
                
                minusBtn.MouseButton1Click:Connect(function() updateSpinner(value - spinStep) end)
                plusBtn.MouseButton1Click:Connect(function() updateSpinner(value + spinStep) end)
                spinInput.FocusLost:Connect(function()
                    local n = tonumber(spinInput.Text)
                    if n then updateSpinner(n) else spinInput.Text = tostring(value) end
                end)
                
                for _, b in ipairs({minusBtn, plusBtn}) do
                    b.MouseEnter:Connect(function()
                        TweenService:Create(b, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(35, 60, 120), TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
                    end)
                    b.MouseLeave:Connect(function()
                        TweenService:Create(b, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(25, 35, 60), TextColor3 = Color3.fromRGB(150, 175, 220)}):Play()
                    end)
                end
                
                Window.States[pageName][rowName].Update = function(val, config)
                    config = config or {}
                    spinMin = config.Min or spinMin
                    spinMax = config.Max or spinMax
                    spinStep = config.Step or spinStep
                    updateSpinner(val)
                end
                updateSpinner(50, true)
            end
            
            -- C. Slider Control
            local sliderTrack = cc:FindFirstChild("Track")
            local sliderValueLabel = cc:FindFirstChild("ValueLabel")
            local fill = sliderTrack and sliderTrack:FindFirstChild("Fill")
            local sliderKnob = sliderTrack and sliderTrack:FindFirstChild("Knob")
            if sliderTrack and sliderValueLabel and fill and sliderKnob then
                Window.States[pageName][rowName].Type = "Slider"
                local sMin, sMax, sValue = 0, 100, 50
                local sUnit = "%"
                
                local function updateSlider(inputObj, silent)
                    local trackAbsPos = sliderTrack.AbsolutePosition
                    local trackAbsSize = sliderTrack.AbsoluteSize
                    local mouseX = inputObj.Position.X
                    local relativeX = math.clamp((mouseX - trackAbsPos.X) / trackAbsSize.X, 0, 1)
                    
                    fill.Size = UDim2.new(relativeX, 0, 1, 0)
                    sliderKnob.Position = UDim2.new(relativeX, 0, 0.5, 0)
                    sValue = sMin + math.round(relativeX * (sMax - sMin))
                    sliderValueLabel.Text = tostring(sValue) .. sUnit
                    
                    Window.States[pageName][rowName].Value = sValue
                    if not silent then
                        for _, cb in ipairs(Window.States[pageName][rowName].Callbacks) do
                            pcall(cb, sValue)
                        end
                    end
                end
                
                sliderTrack.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        local sliding = true
                        updateSlider(input, false)
                        local mConn, rConn
                        mConn = UserInputService.InputChanged:Connect(function(moveInput)
                            if sliding and (moveInput.UserInputType == Enum.UserInputType.MouseMovement or moveInput.UserInputType == Enum.UserInputType.Touch) then
                                updateSlider(moveInput, false)
                            end
                        end)
                        rConn = UserInputService.InputEnded:Connect(function(releaseInput)
                            if releaseInput.UserInputType == Enum.UserInputType.MouseButton1 or releaseInput.UserInputType == Enum.UserInputType.Touch then
                                sliding = false
                                mConn:Disconnect()
                                rConn:Disconnect()
                            end
                        end)
                    end
                end)
                
                Window.States[pageName][rowName].Update = function(val, config)
                    config = config or {}
                    sMin = config.Min or sMin
                    sMax = config.Max or sMax
                    sUnit = config.Unit or sUnit
                    sValue = val
                    local r = (val - sMin) / (sMax - sMin)
                    fill.Size = UDim2.new(r, 0, 1, 0)
                    sliderKnob.Position = UDim2.new(r, 0, 0.5, 0)
                    sliderValueLabel.Text = tostring(val) .. sUnit
                    Window.States[pageName][rowName].Value = val
                    for _, cb in ipairs(Window.States[pageName][rowName].Callbacks) do
                        pcall(cb, val)
                    end
                end
            end
            
            -- D. InputBox Control
            local inputTextBox = cc:FindFirstChild("TextBox")
            if inputTextBox and not minusBtn then -- Check not spinner
                Window.States[pageName][rowName].Type = "Input"
                local iStroke = inputTextBox:FindFirstChildWhichIsA("UIStroke")
                inputTextBox.Focused:Connect(function()
                    if iStroke then TweenService:Create(iStroke, TweenInfo.new(0.15), {Color = Color3.fromRGB(0, 110, 255)}):Play() end
                end)
                inputTextBox.FocusLost:Connect(function()
                    if iStroke then TweenService:Create(iStroke, TweenInfo.new(0.15), {Color = Color3.fromRGB(30, 42, 75)}):Play() end
                    local text = inputTextBox.Text
                    Window.States[pageName][rowName].Value = text
                    for _, cb in ipairs(Window.States[pageName][rowName].Callbacks) do
                        pcall(cb, text)
                    end
                end)
                
                Window.States[pageName][rowName].Update = function(val)
                    inputTextBox.Text = tostring(val)
                    Window.States[pageName][rowName].Value = val
                    for _, cb in ipairs(Window.States[pageName][rowName].Callbacks) do
                        pcall(cb, val)
                    end
                end
            end
            
            -- E. ColorPicker Control
            local colorBtn = cc:FindFirstChild("ColorBtn")
            if colorBtn then
                Window.States[pageName][rowName].Type = "Colorpicker"
                
                colorBtn.MouseButton1Click:Connect(function()
                    local h, s, v = Color3.toHSV(colorBtn.BackgroundColor3)
                    
                    picker.Position = UDim2.new(0, colorBtn.AbsolutePosition.X - 220, 0, colorBtn.AbsolutePosition.Y - 80)
                    picker.Visible = true
                    
                    -- Setup connection for picker apply
                    local applyBtn = picker:WaitForChild("BottomBar"):WaitForChild("ApplyBtn")
                    local satValCanvas = picker:WaitForChild("SatValCanvas")
                    local hueSlider = picker:WaitForChild("HueSlider")
                    local hexInput = picker.BottomBar:WaitForChild("HexInput")
                    
                    satValCanvas.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                    satValCanvas.Pin.Position = UDim2.new(s, 0, 1 - v, 0)
                    hueSlider.Pin.Position = UDim2.new(h, 0, 0.5, 0)
                    picker.BottomBar.Preview.BackgroundColor3 = colorBtn.BackgroundColor3
                    hexInput.Text = rgbToHex(colorBtn.BackgroundColor3)
                    
                    local activeH, activeS, activeV = h, s, v
                    
                    local function updateInnerUI()
                        local base = Color3.fromHSV(activeH, 1, 1)
                        local selected = Color3.fromHSV(activeH, activeS, activeV)
                        satValCanvas.BackgroundColor3 = base
                        picker.BottomBar.Preview.BackgroundColor3 = selected
                        hexInput.Text = rgbToHex(selected)
                    end
                    
                    -- SatVal Dragging
                    local satValDragging = false
                    satValCanvas.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                            satValDragging = true
                            local function updateSV(inputObj)
                                local relX = math.clamp((inputObj.Position.X - satValCanvas.AbsolutePosition.X) / satValCanvas.AbsoluteSize.X, 0, 1)
                                local relY = math.clamp((inputObj.Position.Y - satValCanvas.AbsolutePosition.Y) / satValCanvas.AbsoluteSize.Y, 0, 1)
                                activeS = relX
                                activeV = 1 - relY
                                satValCanvas.Pin.Position = UDim2.new(relX, 0, relY, 0)
                                updateInnerUI()
                            end
                            updateSV(input)
                            local m, r
                            m = UserInputService.InputChanged:Connect(function(moveInput)
                                if satValDragging and (moveInput.UserInputType == Enum.UserInputType.MouseMovement or moveInput.UserInputType == Enum.UserInputType.Touch) then
                                    updateSV(moveInput)
                                end
                            end)
                            r = UserInputService.InputEnded:Connect(function(releaseInput)
                                if releaseInput.UserInputType == Enum.UserInputType.MouseButton1 or releaseInput.UserInputType == Enum.UserInputType.Touch then
                                    satValDragging = false
                                    m:Disconnect()
                                    r:Disconnect()
                                end
                            end)
                        end
                    end)
                    
                    -- Hue Slider Dragging
                    local hueDragging = false
                    hueSlider.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                            hueDragging = true
                            local function updateH(inputObj)
                                local relX = math.clamp((inputObj.Position.X - hueSlider.AbsolutePosition.X) / hueSlider.AbsoluteSize.X, 0, 1)
                                activeH = relX
                                hueSlider.Pin.Position = UDim2.new(relX, 0, 0.5, 0)
                                updateInnerUI()
                            end
                            updateH(input)
                            local m, r
                            m = UserInputService.InputChanged:Connect(function(moveInput)
                                if hueDragging and (moveInput.UserInputType == Enum.UserInputType.MouseMovement or moveInput.UserInputType == Enum.UserInputType.Touch) then
                                    updateH(moveInput)
                                end
                            end)
                            r = UserInputService.InputEnded:Connect(function(releaseInput)
                                if releaseInput.UserInputType == Enum.UserInputType.MouseButton1 or releaseInput.UserInputType == Enum.UserInputType.Touch then
                                    hueDragging = false
                                    m:Disconnect()
                                    r:Disconnect()
                                end
                            end)
                        end
                    end)
                    
                    local applyConn
                    applyConn = applyBtn.MouseButton1Click:Connect(function()
                        applyConn:Disconnect()
                        picker.Visible = false
                        local finalColor = Color3.fromHSV(activeH, activeS, activeV)
                        colorBtn.BackgroundColor3 = finalColor
                        
                        Window.States[pageName][rowName].Value = finalColor
                        for _, cb in ipairs(Window.States[pageName][rowName].Callbacks) do
                            pcall(cb, finalColor)
                        end
                    end)
                    
                    -- Tactile
                    local shrink = TweenService:Create(colorBtn, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(0, 24, 0, 14)})
                    local restore = TweenService:Create(colorBtn, TweenInfo.new(0.12, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, 28, 0, 18)})
                    shrink:Play() task.wait(0.08) restore:Play()
                end)
                
                Window.States[pageName][rowName].Update = function(color)
                    colorBtn.BackgroundColor3 = color
                    Window.States[pageName][rowName].Value = color
                    for _, cb in ipairs(Window.States[pageName][rowName].Callbacks) do
                        pcall(cb, color)
                    end
                end
            end
            
            -- F. ActionButton Control
            local actBtn = cc:FindFirstChild("Button")
            if actBtn then
                Window.States[pageName][rowName].Type = "Button"
                actBtn.MouseButton1Click:Connect(function()
                    local shrink = TweenService:Create(actBtn, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(0, 74, 0, 18)})
                    local restore = TweenService:Create(actBtn, TweenInfo.new(0.12, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, 80, 0, 22)})
                    shrink:Play() task.wait(0.08) restore:Play()
                    
                    for _, cb in ipairs(Window.States[pageName][rowName].Callbacks) do
                        pcall(cb)
                    end
                end)
            end
        end
    end
    
    -- Dynamically initialize all elements on load
    for _, page in ipairs(mainPanel:GetChildren()) do
        if page:IsA("ScrollingFrame") and page.Name:match("^Page_") then
            local pageName = page.Name
            Window.States[pageName] = {}
            for _, row in ipairs(page:GetChildren()) do
                if row:IsA("Frame") and row.Name:match("^Row_") then
                    initRowInteractive(row, pageName, row.Name)
                end
            end
        end
    end
    
    -- Global keybind listener
    UserInputService.InputBegan:Connect(function(input, gp)
        if gp or UserInputService:GetFocusedTextBox() or isBindingAnyKey then return end
        
        for pName, pageBinds in pairs(Window.States) do
            for rName, bind in pairs(pageBinds) do
                local match = false
                if bind.Key and bind.Key ~= "None" then
                    if type(bind.Key) == "userdata" then
                        match = (bind.Key.EnumType == Enum.KeyCode and input.KeyCode == bind.Key) or (bind.Key.EnumType == Enum.UserInputType and input.UserInputType == bind.Key)
                    end
                end
                
                if match and bind.Type == "Toggle" then
                    local newState = not bind.Value
                    if bind.Update then bind.Update(newState) end
                    
                    local activePage = mainPanel:FindFirstChild(pName)
                    local row = activePage and activePage:FindFirstChild(rName)
                    local title = row and row:FindFirstChild("Title") and row.Title.Text or "Feature"
                    SysUI:Notify({Title = title, Content = newState and "Activated successfully!" or "Deactivated successfully!", Duration = 3})
                end
            end
        end
    end)
    
    -- Parent ScreenGui to PlayerGui
    gui.Parent = PlayerGui
    
    SysUI.ActiveWindow = Window
    return Window
end

