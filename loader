-- bind config
function WindowClass:BindConfigActions(config)
    config = config or {}
    local onLoad = config.OnLoad or nil
    local onSave = config.OnSave or nil
    
    local settingsPanel = self.MainPanel:FindFirstChild("SettingsPanel")
    local configContainer = settingsPanel and settingsPanel:FindFirstChild("ConfigContainer")
    local loadBtn = configContainer and configContainer:FindFirstChild("LoadConfigBtn")
    local saveBtn = configContainer and configContainer:FindFirstChild("SaveConfigBtn")
    
    local window = self
    
    local function hook(btn, callback, isSave)
        local stroke = btn:FindFirstChildWhichIsA("UIStroke")
        
        btn.MouseEnter:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 130, 255)}):Play()
            if stroke then TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(0, 220, 255), Transparency = 0.2}):Play() end
        end)
        btn.MouseLeave:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 110, 255)}):Play()
            if stroke then TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(60, 140, 255), Transparency = 0.5}):Play() end
        end)
        
        btn.Activated:Connect(function()
            local targetSize = btn.Size
            local shrinkSize = UDim2.new(0, targetSize.X.Offset - 8, 0, targetSize.Y.Offset - 2)
            
            local shrink = TweenService:Create(btn, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = shrinkSize})
            local restore = TweenService:Create(btn, TweenInfo.new(0.12, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = targetSize})
            
            shrink:Play() task.wait(0.08) restore:Play()
            
            if callback then
                callback()
            elseif isSave then
                window:SaveConfig()
            else
                window:LoadConfig()
            end
        end)
    end
    
    if loadBtn then hook(loadBtn, onLoad, false) end
    if saveBtn then hook(saveBtn, onSave, true) end
end

-- save config
function WindowClass:SaveConfig(filename)
    filename = filename or "syshub_config.json"
    local HttpService = game:GetService("HttpService")
    
    local data = { States = {} }
    for pageName, pageStates in pairs(self.States) do
        data.States[pageName] = {}
        for rowName, state in pairs(pageStates) do
            local entry = { Type = state.Type, Value = state.Value }
            
            -- Serialize Key
            if state.Key and state.Key ~= "None" then
                if typeof(state.Key) == "EnumItem" then
                    entry.KeyType = tostring(state.Key.EnumType)
                    entry.KeyValue = state.Key.Name
                else
                    entry.KeyType = "string"
                    entry.KeyValue = tostring(state.Key)
                end
            end
            
            -- Serialize Color
            if typeof(state.Value) == "Color3" then
                entry.Value = rgbToHex(state.Value)
                entry.IsColor = true
            end
            
            data.States[pageName][rowName] = entry
        end
    end
    
    local json = HttpService:JSONEncode(data)
    
    local ok, err = pcall(function()
        if writefile then
            writefile(filename, json)
        else
            HttpService:PostAsync("http://127.0.0.1:8082/save_config", json)
        end
    end)
    
    SysUI:Notify({
        Title = "Configuration",
        Content = ok and "Profile saved successfully!" or ("Save failed: " .. tostring(err)),
        Duration = 3.5
    })
    return ok
end

-- load config
function WindowClass:LoadConfig(filename)
    filename = filename or "syshub_config.json"
    local HttpService = game:GetService("HttpService")
    
    local json
    local ok, err = pcall(function()
        if readfile then
            json = readfile(filename)
        else
            json = HttpService:GetAsync("http://127.0.0.1:8082/load_config")
        end
    end)
    
    if not ok or not json or json == "" then
        SysUI:Notify({Title = "Configuration", Content = "No saved profile found.", Duration = 3.5})
        return false
    end
    
    local data = HttpService:JSONDecode(json)
    if not data or not data.States then
        SysUI:Notify({Title = "Configuration", Content = "Failed to parse profile.", Duration = 3.5})
        return false
    end
    
    for pageName, pageStates in pairs(data.States) do
        if self.States[pageName] then
            for rowName, saved in pairs(pageStates) do
                local state = self.States[pageName][rowName]
                if state and state.Update then
                    local value = saved.Value
                    
                    -- Restore Color
                    if saved.IsColor then
                        value = hexToRgb(tostring(saved.Value))
                    end
                    
                    state.Update(value, false)
                end
                
                -- Restore Key
                if saved.KeyValue and self.States[pageName][rowName] then
                    local keyVal
                    if saved.KeyType == "string" then
                        keyVal = saved.KeyValue
                    else
                        local enumType = saved.KeyType == "Enum.KeyCode" and Enum.KeyCode or Enum.UserInputType
                        pcall(function() keyVal = enumType[saved.KeyValue] end)
                        keyVal = keyVal or saved.KeyValue
                    end
                    self.States[pageName][rowName].Key = keyVal
                end
            end
        end
    end
    
    SysUI:Notify({Title = "Configuration", Content = "Profile loaded successfully!", Duration = 3.5})
    return true
end

return SysUI
