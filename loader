-- WRAPPER BINDING APIS (Hook functions to named Rows)
-- ============================================================
-- helper to get a state object from page & row name
local function getState(window, pageName, rowName)
    local page = window.States[pageName]
    local state = page and page[rowName]
    if not state then
        warn(string.format("[SysUI] State for row '%s' on page '%s' not found!", tostring(rowName), tostring(pageName)))
    end
    return state
end
-- 1. Bind Toggle
local PageRowTypes = {
    Page_1_A = {
        Toggle = {"Row_A", "Row_E", "Row_H"},
        Slider = {"Row_B", "Row_F"},
        Spinner = {"Row_C"},
        Input = {"Row_D"},
        Dropdown = {"Row_G"}
    },
    Page_1_B = {
        Dropdown = {"Row_A"},
        Toggle = {"Row_B", "Row_F"},
        Slider = {"Row_C", "Row_G"},
        ColorPicker = {"Row_D"},
        Spinner = {"Row_E"},
        Button = {"Row_H"}
    },
    Page_1_C = {
        Slider = {"Row_A", "Row_D"},
        Dropdown = {"Row_B"},
        ColorPicker = {"Row_C"},
        Spinner = {"Row_E"},
        Toggle = {"Row_F"},
        Input = {"Row_G"},
        Button = {"Row_H"}
    }
}
function WindowClass:CreateTab(tabDisplayName)
    local pageName
    if tabDisplayName == "Combat" then
        pageName = "Page_1_A"
    elseif tabDisplayName == "Visuals" then
        pageName = "Page_1_B"
    elseif tabDisplayName == "Misc" then
        pageName = "Page_1_C"
    else
        error("Tab name must be 'Combat', 'Visuals', or 'Misc'")
    end

    local tabObj = {}
    tabObj.PageName = pageName
    tabObj.UsedIndices = {
        Toggle = 0,
        Slider = 0,
        Spinner = 0,
        Input = 0,
        Dropdown = 0,
        ColorPicker = 0,
        Button = 0
    }
    
    local pageRowMap = PageRowTypes[pageName]
    local windowSelf = self

    local function getNextRow(controlType)
        local list = pageRowMap[controlType]
        if not list then return nil end
        local idx = tabObj.UsedIndices[controlType] + 1
        if idx > #list then
            warn("No more available rows for control type: " .. tostring(controlType) .. " on page " .. tostring(pageName))
            return nil
        end
        tabObj.UsedIndices[controlType] = idx
        return list[idx]
    end

    local function configureRowBase(row, name, hasToggle, hasKeybind, toggleConfig, keybindConfig)
        if not row then return end
        row.Visible = true
        
        -- Configure Title
        local titleLabel = row:FindFirstChild("Title")
        if titleLabel then
            titleLabel.Text = name
            titleLabel.ZIndex = 8
            titleLabel.Visible = true
        end

        -- Configure Toggle Switch on the right side of this row
        local toggleFrame = row:FindFirstChild("Toggle")
        if toggleFrame then
            toggleFrame.Visible = (hasToggle == true)
            if hasToggle and toggleConfig then
                local def = toggleConfig.Default or false
                local cb = toggleConfig.Callback or function() end
                windowSelf:BindToggle(pageName, row.Name, {Default = def, Callback = cb})
            end
        end

        -- Configure Keybind Button
        local kbBtn = row:FindFirstChild("KeybindButton")
        if kbBtn then
            kbBtn.Visible = (hasKeybind == true)
            kbBtn.ZIndex = 8
            if hasKeybind and keybindConfig then
                local def = keybindConfig.Default or keybindConfig.Key or Enum.KeyCode.F
                local cb = keybindConfig.Callback or function() end
                windowSelf:BindKeybind(pageName, row.Name, {Default = def, Callback = cb})
            end
        end
    end

    -- 1. AddToggle
    function tabObj:AddToggle(name, config)
        local rowName = getNextRow("Toggle")
        if not rowName then return end
        
        local page = windowSelf.MainPanel:FindFirstChild(pageName)
        local row = page and page:FindFirstChild(rowName)
        
        if type(config) == "function" then
            config = { Callback = config }
        elseif type(config) == "boolean" then
            config = { Default = config }
        end
        config = config or {}
        
        local hasKeybind = (config.Keybind ~= nil)
        local keybindConfig = nil
        if hasKeybind then
            keybindConfig = {
                Default = config.Keybind,
                Callback = config.KeybindCallback
            }
        end
        
        configureRowBase(row, name, true, hasKeybind, config, keybindConfig)
        
        -- Hide custom control just in case
        local cc = row and row:FindFirstChild("CustomControl")
        if cc then cc.Visible = false end
    end

    -- 2. AddSlider
    function tabObj:AddSlider(name, config)
        local rowName = getNextRow("Slider")
        if not rowName then return end
        
        local page = windowSelf.MainPanel:FindFirstChild(pageName)
        local row = page and page:FindFirstChild(rowName)
        
        config = config or {}
        local hasToggle = (config.Toggle ~= nil)
        local hasKeybind = (config.Keybind ~= nil)
        
        configureRowBase(row, name, hasToggle, hasKeybind, config.Toggle, config.Keybind)
        
        local cc = row and row:FindFirstChild("CustomControl")
        if cc then cc.Visible = true end
        
        windowSelf:BindSlider(pageName, rowName, {
            Min = config.Min,
            Max = config.Max,
            Default = config.Default,
            Unit = config.Unit,
            Callback = config.Callback
        })
    end

    -- 3. AddSpinner
    function tabObj:AddSpinner(name, config)
        local rowName = getNextRow("Spinner")
        if not rowName then return end
        
        local page = windowSelf.MainPanel:FindFirstChild(pageName)
        local row = page and page:FindFirstChild(rowName)
        
        config = config or {}
        local hasToggle = (config.Toggle ~= nil)
        local hasKeybind = (config.Keybind ~= nil)
        
        configureRowBase(row, name, hasToggle, hasKeybind, config.Toggle, config.Keybind)
        
        local cc = row and row:FindFirstChild("CustomControl")
        if cc then cc.Visible = true end
        
        windowSelf:BindSpinner(pageName, rowName, {
            Min = config.Min,
            Max = config.Max,
            Default = config.Default,
            Step = config.Step,
