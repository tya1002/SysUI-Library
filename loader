            task.wait(0.5)
            mainFrame.Visible = false
        end
        minimizedWidget.Visible = true
        startSpin()
    end
    
    local function animateRestore()
        stopSpin()
        minimizedWidget.Visible = false
        local info = TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        
        if currentActiveFrame == "LoginFrame" then
