--[[
    SysUI Library - Premium GUI Wrapper Library (SysHubUI Edition)
    Wraps around the pre-built `SysHubUI` ScreenGui template.
    Allows scripters to load their pre-made GUI design and bind callbacks 
    to rows, buttons, toggles, sliders, dropdowns, inputs, color pickers, and keybinds.
]]

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local SysUI = {
    Notifications = {},
    ActiveWindow = nil
}

-- Lexical Scoping Declarations
local WindowClass = {}
WindowClass.__index = WindowClass

-- Helper: Format Keybind Key Name
local function formatKeyName(input)
    if input == "None" or not input then return "..." end
    if type(input) == "string" then return input end
    local name = tostring(input):gsub("Enum%.KeyCode%.",""):gsub("Enum%.UserInputType%.","")
    if name == "LeftAlt" then return "LAlt" end
    if name == "RightAlt" then return "RAlt" end
    if name == "LeftControl" then return "LCtrl" end
    if name == "RightControl" then return "RCtrl" end
    if name == "LeftShift" then return "LShift" end
    if name == "RightShift" then return "RShift" end
    if name == "MouseButton1" then return "M1" end
    if name == "MouseButton2" then return "M2" end
    if name == "MouseButton3" then return "M3" end
    return name
end

-- Helper: Convert RGB to HEX String
local function rgbToHex(color)
    return string.format("#%02X%02X%02X", math.round(color.R * 255), math.round(color.G * 255), math.round(color.B * 255))
end

-- Helper: Convert HEX String to Color3
local function hexToRgb(hex)
    hex = hex:gsub("#", "")
    if #hex ~= 6 then return Color3.fromRGB(255, 0, 0) end
    local r = tonumber(hex:sub(1, 2), 16) or 255
    local g = tonumber(hex:sub(3, 4), 16) or 0
    local b = tonumber(hex:sub(5, 6), 16) or 0
    return Color3.fromRGB(r, g, b)
end

-- ============================================================
-- TOAST NOTIFICATION SYSTEM
-- ============================================================
function SysUI:Notify(config)
    config = config or {}
    local title = config.Title or "Notification"
    local message = config.Content or ""
    local duration = config.Duration or 3.5
    
    local screenGui = SysUI.ActiveWindow and SysUI.ActiveWindow.Gui
    if not screenGui then return end
    
    local template = screenGui:FindFirstChild("NotificationTemplate")
    if not template then return end
    
    local notif = template:Clone()
    notif.Name = "Notification"
    notif.Title.Text = title
    notif.Message.Text = message
    notif.Visible = true
    notif.Parent = screenGui
    
    table.insert(SysUI.Notifications, 1, notif)
    
    local function reposition()
        for i, card in ipairs(SysUI.Notifications) do
            local targetY = -80 - (i - 1) * 65
            TweenService:Create(card, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = UDim2.new(1, -20, 1, targetY)}):Play()
        end
    end
    
    notif.Position = UDim2.new(1, 300, 1, -80)
    reposition()
    
    TweenService:Create(notif, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(1, -20, 1, -80)}):Play()
    
    task.delay(duration, function()
        local idx = table.find(SysUI.Notifications, notif)
        if idx then table.remove(SysUI.Notifications, idx) end
        
        local slideOut = TweenService:Create(notif, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Position = UDim2.new(1, 300, notif.Position.Y.Scale, notif.Position.Y.Offset)})
        slideOut:Play()
        reposition()
        
        slideOut.Completed:Wait()
        notif:Destroy()
    end)
end

-- ============================================================
-- DRAGGABLE & RESIZABLE HANDLER
-- ============================================================
local function setupDraggableAndResizable(frame, dragHandles, minSize, maxSize, onResizeEnd)
    local dragging = false
    local dragInput, dragStart, startPos
    
    for _, handle in ipairs(dragHandles) do
        handle.Active = true
        handle.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                dragStart = input.Position
                startPos = frame.Position
                
                local conn
                conn = input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        dragging = false
                        conn:Disconnect()
                    end
                end)
            end
        end)
        
        handle.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                dragInput = input
            end
        end)
    end
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input == dragInput then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
    
    local resizeGrip = frame:FindFirstChild("ResizeGrip")
    if resizeGrip then
        local resizing = false
        local startSize, startFramePos, resizeStart
        
        resizeGrip.MouseEnter:Connect(function()
            TweenService:Create(resizeGrip, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(0, 220, 255), TextTransparency = 0.2}):Play()
        end)
        resizeGrip.MouseLeave:Connect(function()
            TweenService:Create(resizeGrip, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(0, 180, 255), TextTransparency = 0.4}):Play()
        end)
        
        resizeGrip.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                resizing = true
                resizeStart = input.Position
                startSize = frame.AbsoluteSize
                startFramePos = frame.Position
                
                local conn
                conn = input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        resizing = false
                        conn:Disconnect()
                        if onResizeEnd then onResizeEnd(frame.Size) end
                    end
                end)
            end
        end)
        
        UserInputService.InputChanged:Connect(function(input)
            if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local delta = input.Position - resizeStart
                local newW = math.clamp(startSize.X + delta.X, minSize.X, maxSize.X)
                local newH = math.clamp(startSize.Y + delta.Y, minSize.Y, maxSize.Y)
                
                local changeW = newW - startSize.X
                local changeH = newH - startSize.Y
                
                frame.Size = UDim2.new(0, newW, 0, newH)
                frame.Position = UDim2.new(
                    startFramePos.X.Scale, startFramePos.X.Offset + changeW * 0.5,
                    startFramePos.Y.Scale, startFramePos.Y.Offset + changeH * 0.5
                )
            end
        end)
    end
end

-- ============================================================
-- LOAD GUI TEMPLATE & INITIALIZE CORE BEHAVIORS
-- ============================================================
function SysUI:Load(config)
    config = config or {}
    local authKey = config.Key
    
    -- Destroy existing clone if any
    local existing = PlayerGui:FindFirstChild("SysHubUI_Loaded")
    if existing then existing:Destroy() end
    
    -- Load the template: First try local sources, then fallback to Roblox Cloud Asset (for executor)
    local template
    local localSource = script:FindFirstChild("SysHubUI") or game.StarterGui:FindFirstChild("SysHubUI")
    
    if localSource then
        template = localSource:Clone()
    else
        local success, asset = pcall(function()
            return game:GetObjects("rbxassetid://89324887405137")[1]
        end)
        if success and asset then
            template = asset
        end
    end
    
    assert(template, "SysHubUI ScreenGui template not found locally or in Roblox Cloud (Asset ID: 89324887405137)!")
    
    local gui = template
    gui.Name = "SysHubUI_Loaded"
    gui.ResetOnSpawn = false
    
    local mainFrame = gui:WaitForChild("MainFrame")
    local loginFrame = gui:WaitForChild("LoginFrame")
    local sidebar = mainFrame:WaitForChild("Sidebar")
    local sidebarScroll = sidebar:WaitForChild("SidebarScroll")
    local mainPanel = mainFrame:WaitForChild("MainPanel")
    local minimizedWidget = gui:WaitForChild("MinimizedWidget")
    local colorPickerWidget = gui:WaitForChild("ColorPickerWidget")
    
    local profileCard = sidebar:WaitForChild("ProfileCard")
    local displayNameLabel = profileCard:WaitForChild("DisplayName")
    local statusLabel = profileCard:WaitForChild("Status")
    
    local header = mainPanel:WaitForChild("Header")
    local titleLabel = header:WaitForChild("Title")
    local subtitleLabel = header:WaitForChild("Subtitle")
    local searchBoxFrame = header:WaitForChild("SearchBox")
    local searchBox = searchBoxFrame:WaitForChild("TextBox")
    
    local aboutPanel = mainPanel:WaitForChild("AboutPanel")
    local settingsPanel = mainPanel:WaitForChild("SettingsPanel")
    
    local btnAbout = sidebarScroll:WaitForChild("Btn_About")
    local btnSettings = sidebarScroll:WaitForChild("Btn_Settings")
    
    -- Local variables for state
    local currentActiveFrame = "LoginFrame"
    local originalLoginSize = loginFrame.Size
    local originalMainSize = mainFrame.Size
    local isBindingAnyKey = false
    local keybindData = {} -- Map page -> row -> keybind settings
    
    -- Display Name
    displayNameLabel.Text = LocalPlayer.DisplayName
    
    -- Setup Windows Drag & Resize
    setupDraggableAndResizable(loginFrame, {loginFrame:WaitForChild("Background")}, Vector2.new(300, 320), Vector2.new(600, 620), function(s) originalLoginSize = s end)
    setupDraggableAndResizable(mainFrame, {sidebar, header}, Vector2.new(500, 350), Vector2.new(1000, 700), function(s) originalMainSize = s end)
    
    -- ============================================================
    -- TAB NAVIGATION SYSTEM
    -- ============================================================
    local function showTab(tabName, groupNum, itemLetter)
        for _, page in ipairs(mainPanel:GetChildren()) do
            if (page:IsA("ScrollingFrame") and page.Name:match("^Page_")) or page.Name == "SettingsPanel" then
                page.Visible = false
            end
        end
        
        if tabName == "About" then
            aboutPanel.Visible = true
            searchBoxFrame.Visible = false
            titleLabel.Text = "Tentang SysHub"
            subtitleLabel.Text = "Premium"
        elseif tabName == "Settings" then
            aboutPanel.Visible = false
            settingsPanel.Visible = true
            searchBoxFrame.Visible = false
            titleLabel.Text = "Settings"
            subtitleLabel.Text = "Visual & UI"
        else
            aboutPanel.Visible = false
            searchBoxFrame.Visible = true
            local pageName = "Page_" .. tostring(groupNum) .. "_" .. tostring(itemLetter)
            local targetPage = mainPanel:FindFirstChild(pageName)
            if targetPage then targetPage.Visible = true end
            titleLabel.Text = "Menu " .. groupNum .. "-" .. itemLetter
            subtitleLabel.Text = "SubMenu " .. groupNum .. "-" .. itemLetter
        end
    end
    
    -- Tab Buttons
    btnAbout.Activated:Connect(function() showTab("About") end)
    btnSettings.Activated:Connect(function() showTab("Settings") end)
    
    -- Hover Transitions for About & Settings
    for _, btn in ipairs({btnAbout, btnSettings}) do
        local lbl = btn:FindFirstChild("Label")
        local stroke = btn:FindFirstChildWhichIsA("UIStroke")
        btn.MouseEnter:Connect(function()
            btn.BackgroundTransparency = 0
            btn.BackgroundColor3 = Color3.fromRGB(20, 50, 130)
            if lbl then lbl.TextColor3 = Color3.fromRGB(255, 255, 255) end
            if stroke then TweenService:Create(stroke, TweenInfo.new(0.15), {Color = Color3.fromRGB(60, 120, 255), Transparency = 0.3}):Play() end
        end)
        btn.MouseLeave:Connect(function()
            btn.BackgroundTransparency = 0.2
            btn.BackgroundColor3 = Color3.fromRGB(10, 18, 45)
            if lbl then lbl.TextColor3 = Color3.fromRGB(140, 165, 210) end
            if stroke then TweenService:Create(stroke, TweenInfo.new(0.15), {Color = Color3.fromRGB(30, 60, 140), Transparency = 0.65}):Play() end
        end)
    end
    
    -- Dropdown Group Menus
    local function setupSidebarGroup(group)
        local h = group:FindFirstChild("Header")
        local sub = group:FindFirstChild("SubItems")
        local arr = h and h:FindFirstChild("Arrow")
        if not h or not sub then return end
        
        local open = false
        h.MouseButton1Click:Connect(function()
            open = not open
            local info = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
            local targetSubH = open and 90 or 0
            local targetGroupH = 30 + targetSubH
            
            TweenService:Create(sub, info, {Size = UDim2.new(1, 0, 0, targetSubH)}):Play()
            TweenService:Create(group, info, {Size = UDim2.new(1, 0, 0, targetGroupH)}):Play()
            if arr then
                arr.Text = open and "▼" or "►"
                TweenService:Create(arr, info, {TextColor3 = open and Color3.fromRGB(80, 160, 255) or Color3.fromRGB(100, 130, 200)}):Play()
            end
        end)
        
        for _, item in ipairs(sub:GetChildren()) do
            if item:IsA("TextButton") then
                local lbl = item:FindFirstChild("Label")
                local stroke = item:FindFirstChildWhichIsA("UIStroke")
                item.MouseEnter:Connect(function()
                    item.BackgroundTransparency = 0
                    item.BackgroundColor3 = Color3.fromRGB(20, 50, 130)
                    if lbl then lbl.TextColor3 = Color3.fromRGB(255, 255, 255) end
                    if stroke then TweenService:Create(stroke, TweenInfo.new(0.15), {Color = Color3.fromRGB(60, 120, 255), Transparency = 0.3}):Play() end
                end)
                item.MouseLeave:Connect(function()
                    item.BackgroundTransparency = 0.2
                    item.BackgroundColor3 = Color3.fromRGB(10, 18, 45)
                    if lbl then lbl.TextColor3 = Color3.fromRGB(140, 165, 210) end
                    if stroke then TweenService:Create(stroke, TweenInfo.new(0.15), {Color = Color3.fromRGB(30, 60, 140), Transparency = 0.65}):Play() end
                end)
                
                item.Activated:Connect(function()
                    local gNum = group.Name:match("^Group_(%d+)") or "1"
                    local iLetter = item.Name:match("^Item_(%a+)") or "A"
                    showTab("Keybinds", gNum, iLetter)
                end)
            end
        end
    end
    
    for _, g in ipairs(sidebarScroll:GetChildren()) do
        if g:IsA("Frame") and g.Name:match("^Group_") then
            setupSidebarGroup(g)
        end
    end
    
    -- ============================================================
    -- LOGO 3D SPIN ANIMATION ON MINIMIZE
    -- ============================================================
    local spinConn
    local function startSpin()
        if spinConn then spinConn:Disconnect() end
        local rSpeed, sSpeed, elapsed = 10, 0.2, 0
        spinConn = RunService.RenderStepped:Connect(function(dt)
            minimizedWidget.Glow.Rotation = (minimizedWidget.Glow.Rotation + rSpeed * dt) % 360
            elapsed = elapsed + dt
            local sx = math.cos(elapsed * sSpeed * math.pi)
            minimizedWidget.Icon.Size = UDim2.new(0, math.abs(sx) * 80, 0, 75)
        end)
    end
    
    local function stopSpin()
        if spinConn then spinConn:Disconnect() spinConn = nil end
        minimizedWidget.Icon.Size = UDim2.new(0, 80, 0, 75)
        minimizedWidget.Glow.Rotation = 0
    end
    
    -- Minimize / Restore Handlers
    local function animateMinimize()
        local info = TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        if currentActiveFrame == "LoginFrame" then
            loginFrame.ClipsDescendants = true
            TweenService:Create(loginFrame, info, {Size = UDim2.new(0, originalLoginSize.X.Offset, 0, 0)}):Play()
            task.wait(0.5)
            loginFrame.Visible = false
        else
            mainFrame.ClipsDescendants = true
            TweenService:Create(mainFrame, info, {Size = UDim2.new(0, originalMainSize.X.Offset, 0, 0)}):Play()
            task.wait(0.5)
            mainFrame.Visible = false
        end
        minimizedWidget.Visible = true
        startSpin()
    end
    
    local function animateRestore()
        stopSpin()
        minimizedWidget.Visible = false
        local info = TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        
        if currentActiveFrame == "LoginFrame" then
            loginFrame.Size = UDim2.new(0, originalLoginSize.X.Offset, 0, 0)
            loginFrame.Visible = true
            loginFrame.ClipsDescendants = true
            local tw = TweenService:Create(loginFrame, info, {Size = originalLoginSize})
            tw:Play()
            task.spawn(function() tw.Completed:Wait() loginFrame.ClipsDescendants = false end)
        else
            mainFrame.Size = UDim2.new(0, originalMainSize.X.Offset, 0, 0)
            mainFrame.Visible = true
            mainFrame.ClipsDescendants = true
            local tw = TweenService:Create(mainFrame, info, {Size = originalMainSize})
            tw:Play()
            task.spawn(function() tw.Completed:Wait() mainFrame.ClipsDescendants = false end)
        end
    end
    
    minimizedWidget.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            local startPos = input.Position
            local conn
            conn = input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    conn:Disconnect()
                    if (input.Position - startPos).Magnitude < 6 then
                        animateRestore()
                    end
                end
            end)
        end
    end)
    
    setupDraggableAndResizable(minimizedWidget, {minimizedWidget}, Vector2.new(40,40), Vector2.new(500,500))
    
    -- Window Control Clicks
    local mainMin = mainFrame:WaitForChild("WindowControls"):WaitForChild("MinimizeBtn")
    local mainClose = mainFrame:WaitForChild("WindowControls"):WaitForChild("CloseBtn")
    local loginMin = loginFrame:WaitForChild("WindowControls"):WaitForChild("MinimizeBtn")
    local loginClose = loginFrame:WaitForChild("WindowControls"):WaitForChild("CloseBtn")
    
    mainMin.MouseButton1Click:Connect(animateMinimize)
    loginMin.MouseButton1Click:Connect(animateMinimize)
    mainClose.MouseButton1Click:Connect(function() gui:Destroy() end)
    loginClose.MouseButton1Click:Connect(function() gui:Destroy() end)
    
    -- Control Buttons Hover Transitions
    for _, btn in ipairs({mainMin, mainClose, loginMin, loginClose}) do
        local icon = btn:FindFirstChild("Icon") or btn:FindFirstChild("IconText")
        local stroke = btn:FindFirstChildWhichIsA("UIStroke")
        btn.MouseEnter:Connect(function()
            if btn.Name == "CloseBtn" then
                TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(180, 40, 40)}):Play()
                if stroke then TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(255, 100, 100), Transparency = 0.2}):Play() end
                if icon and icon:IsA("ImageLabel") then TweenService:Create(icon, TweenInfo.new(0.2), {ImageColor3 = Color3.fromRGB(255, 255, 255)}):Play() end
            else
                TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(40, 60, 110)}):Play()
                if stroke then TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(80, 120, 255), Transparency = 0.2}):Play() end
                if icon and icon:IsA("ImageLabel") then TweenService:Create(icon, TweenInfo.new(0.2), {ImageColor3 = Color3.fromRGB(255, 255, 255)}):Play() end
            end
        end)
        btn.MouseLeave:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(20, 26, 46)}):Play()
            if stroke then TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(30, 42, 75), Transparency = 0.5}):Play() end
            if icon and icon:IsA("ImageLabel") then TweenService:Create(icon, TweenInfo.new(0.2), {ImageColor3 = Color3.fromRGB(150, 170, 210)}):Play() end
        end)
    end
    
    -- ============================================================
    -- LOGIN FLOW EXECUTION
    -- ============================================================
    local function executeLogin(isPremiumKey)
        statusLabel.Text = isPremiumKey and "Status : Premium" or "Status : Free"
        currentActiveFrame = "MainFrame"
        
        loginFrame.ClipsDescendants = true
        local info = TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        TweenService:Create(loginFrame, info, {Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1}):Play()
        for _, child in ipairs(loginFrame:GetDescendants()) do
            if child:IsA("GuiObject") then
                if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("TextBox") then
                    TweenService:Create(child, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
                elseif child:IsA("ImageLabel") then
                    TweenService:Create(child, TweenInfo.new(0.3), {ImageTransparency = 1}):Play()
                end
            elseif child:IsA("UIStroke") then
                TweenService:Create(child, TweenInfo.new(0.3), {Transparency = 1}):Play()
            end
        end
        
        task.wait(0.5)
        loginFrame.Visible = false
        
        -- Slide Open MainFrame
        mainFrame.Size = UDim2.new(0, 0, 0, 0)
        mainFrame.Visible = true
        TweenService:Create(mainFrame, TweenInfo.new(0.7, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = originalMainSize}):Play()
        
        showTab("About")
        SysUI:Notify({
            Title = "System Authorization",
            Content = isPremiumKey and "Welcome back! Premium authorized." or "Welcome! Free access authorized.",
            Duration = 3.5
        })
    end
    
    local keyInput = loginFrame:WaitForChild("KeyInput")
    local loginBtn = loginFrame:WaitForChild("LoginBtn")
    local premiumBtn = loginFrame:WaitForChild("OptionsContainer"):WaitForChild("PremiumBtn")
    local freeBtn = loginFrame:WaitForChild("OptionsContainer"):WaitForChild("FreeBtn")
    
    premiumBtn.Activated:Connect(function() keyInput.Text = "SysHub-Premium-Key" end)
    freeBtn.Activated:Connect(function() keyInput.Text = "SysHub-Free-Key" end)
    
    loginBtn.Activated:Connect(function()
        local k = keyInput.Text
        if k == "" then
            -- Shake
            local originalPos = loginFrame.Position
            for i = 1, 6 do
                local offset = (i % 2 == 0) and 8 or -8
                loginFrame.Position = UDim2.new(originalPos.X.Scale, originalPos.X.Offset + offset, originalPos.Y.Scale, originalPos.Y.Offset)
                task.wait(0.04)
            end
            loginFrame.Position = originalPos
            return
        end
        
        local isPremium = not k:lower():find("free")
        executeLogin(isPremium)
    end)
    
    -- Auto-skip login if authorization key is pre-set
    if authKey then
        task.spawn(function()
            task.wait(0.1)
            executeLogin(not authKey:lower():find("free"))
        end)
    end
    
    -- Discord Button
    local dcBtn = aboutPanel:WaitForChild("AboutScroll"):WaitForChild("DiscordContainer"):WaitForChild("DiscordBtn")
    dcBtn.Activated:Connect(function()
        if setclipboard then pcall(function() setclipboard("https://discord.gg/syshub") end) end
        SysUI:Notify({Title = "Discord Link", Content = "Discord link copied to clipboard!", Duration = 3})
    end)
    
    -- Search filtering
    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        local q = searchBox.Text:lower()
        for _, page in ipairs(mainPanel:GetChildren()) do
            if page:IsA("ScrollingFrame") and page.Name:match("^Page_") then
                for _, r in ipairs(page:GetChildren()) do
                    if r:IsA("Frame") and r.Name:match("^Row_") then
                        local t = r:FindFirstChild("Title") and r.Title.Text or ""
                        r.Visible = q == "" or t:lower():find(q, 1, true) ~= nil
                    end
                end
            end
        end
    end)
    
    -- Global keybind listener
    UserInputService.InputBegan:Connect(function(input, gp)
        if gp or UserInputService:GetFocusedTextBox() or isBindingAnyKey then return end
        
        for pName, pageBinds in pairs(keybindData) do
            for rName, bind in pairs(pageBinds) do
                local match = false
                if bind.Key and bind.Key ~= "None" then
                    if type(bind.Key) == "userdata" then
                        match = (bind.Key.EnumType == Enum.KeyCode and input.KeyCode == bind.Key) or (bind.Key.EnumType == Enum.UserInputType and input.UserInputType == bind.Key)
                    end
                end
                
                if match then
                    bind.State = not bind.State
                    bind.Callback(bind.State)
                    
                    -- Sync UI Toggle switch visual if active
                    local activePage = mainPanel:FindFirstChild(pName)
                    local row = activePage and activePage:FindFirstChild(rName)
                    local tf = row and row:FindFirstChild("Toggle")
                    if tf then
                        local sw = tf:FindFirstChild("Switch")
                        local sl = tf:FindFirstChild("StatusLabel")
                        local knob = sw and sw:FindFirstChild("Knob")
                        if knob then
                            local kp = bind.State and UDim2.new(0, 19, 0.5, 0) or UDim2.new(0, 3, 0.5, 0)
                            local bc = bind.State and Color3.fromRGB(0, 85, 255) or Color3.fromRGB(20, 26, 46)
                            TweenService:Create(knob, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = kp}):Play()
                            TweenService:Create(sw, TweenInfo.new(0.2), {BackgroundColor3 = bc}):Play()
                            if sl then
                                sl.Text = bind.State and "ON" or "OFF"
                                sl.TextColor3 = bind.State and Color3.fromRGB(0, 130, 255) or Color3.fromRGB(100, 115, 135)
                            end
                        end
                    end
                    
                    local title = row and row:FindFirstChild("Title") and row.Title.Text or "Feature"
                    SysUI:Notify({Title = title, Content = bind.State and "Activated successfully!" or "Deactivated successfully!", Duration = 3})
                end
            end
        end
    end)
    
    -- Parent ScreenGui to PlayerGui
    gui.Parent = PlayerGui
    
    local Window = setmetatable({
        Gui = gui,
        Main = mainFrame,
        MainPanel = mainPanel,
        ColorPicker = colorPickerWidget,
        KeybindData = keybindData
    }, WindowClass)
    
    SysUI.ActiveWindow = Window
    return Window
end

