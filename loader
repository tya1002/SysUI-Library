local SysUI = {
    Notifications = {},
    ActiveWindow = nil
}
-- Lexical Scoping Declarations
local WindowClass = {}
WindowClass.__index = WindowClass
-- Helper: Format Keybind Key Name
local function formatKeyName(input)
    if input == "None" or not input then return "..." end
    if type(input) == "string" then return input end
    local name = tostring(input):gsub("Enum%.KeyCode%.",""):gsub("Enum%.UserInputType%.","")
    if name == "LeftAlt" then return "LAlt" end
    if name == "RightAlt" then return "RAlt" end
    if name == "LeftControl" then return "LCtrl" end
    if name == "RightControl" then return "RCtrl" end
    if name == "LeftShift" then return "LShift" end
    if name == "RightShift" then return "RShift" end
    if name == "MouseButton1" then return "M1" end
    if name == "MouseButton2" then return "M2" end
    if name == "MouseButton3" then return "M3" end
    return name
end
-- Helper: Convert RGB to HEX String
local function rgbToHex(color)
    return string.format("#%02X%02X%02X", math.round(color.R * 255), math.round(color.G * 255), math.round(color.B * 255))
end
-- Helper: Convert HEX String to Color3
local function hexToRgb(hex)
    hex = hex:gsub("#", "")
    if #hex ~= 6 then return Color3.fromRGB(255, 0, 0) end
    local r = tonumber(hex:sub(1, 2), 16) or 255
    local g = tonumber(hex:sub(3, 4), 16) or 0
    local b = tonumber(hex:sub(5, 6), 16) or 0
    return Color3.fromRGB(r, g, b)
end
-- Notif System
function SysUI:Notify(config)
    config = config or {}
    local title = config.Title or "Notification"
    local message = config.Content or ""
    local duration = config.Duration or 3.5
    
    local screenGui = SysUI.ActiveWindow and SysUI.ActiveWindow.Gui
    if not screenGui then return end
    
    local template = screenGui:FindFirstChild("NotificationTemplate")
    if not template then return end
    
    local notif = template:Clone()
    notif.Name = "Notification"
    notif.Title.Text = title
    notif.Message.Text = message
    notif.Visible = true
    notif.Parent = screenGui
    
    table.insert(SysUI.Notifications, 1, notif)
    
    local function reposition()
        for i, card in ipairs(SysUI.Notifications) do
            local targetY = -80 - (i - 1) * 65
            TweenService:Create(card, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = UDim2.new(1, -20, 1, targetY)}):Play()
        end
    end
    
    notif.Position = UDim2.new(1, 300, 1, -80)
    reposition()
    
    TweenService:Create(notif, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(1, -20, 1, -80)}):Play()
    
    task.delay(duration, function()
        local idx = table.find(SysUI.Notifications, notif)
        if idx then table.remove(SysUI.Notifications, idx) end
        
        local slideOut = TweenService:Create(notif, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Position = UDim2.new(1, 300, notif.Position.Y.Scale, notif.Position.Y.Offset)})
        slideOut:Play()
        reposition()
        
        slideOut.Completed:Wait()
        notif:Destroy()
    end)
end
-- DRAGGABLE & RESIZABLE HANDLER
local function setupDraggableAndResizable(frame, dragHandles, minSize, maxSize, onResizeEnd)
    local dragging = false
    local dragInput, dragStart, startPos
    
    for _, handle in ipairs(dragHandles) do
        handle.Active = true
        handle.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                dragStart = input.Position
                startPos = frame.Position
                
                local conn
                conn = input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        dragging = false
                        conn:Disconnect()
                    end
                end)
            end
        end)
        
        handle.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                dragInput = input
            end
        end)
    end
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input == dragInput then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
    
    local resizeGrip = frame:FindFirstChild("ResizeGrip")
    if resizeGrip then
        local resizing = false
        local startSize, startFramePos, resizeStart
        
        resizeGrip.MouseEnter:Connect(function()
            TweenService:Create(resizeGrip, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(0, 220, 255), TextTransparency = 0.2}):Play()
        end)
        resizeGrip.MouseLeave:Connect(function()
            TweenService:Create(resizeGrip, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(0, 180, 255), TextTransparency = 0.4}):Play()
        end)
        
        resizeGrip.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                resizing = true
                resizeStart = input.Position
                startSize = frame.AbsoluteSize
                startFramePos = frame.Position
                
                local conn
                conn = input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        resizing = false
                        conn:Disconnect()
                        if onResizeEnd then onResizeEnd(frame.Size) end
                    end
                end)
            end
        end)
        
        UserInputService.InputChanged:Connect(function(input)
            if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local delta = input.Position - resizeStart
                local newW = math.clamp(startSize.X + delta.X, minSize.X, maxSize.X)
                local newH = math.clamp(startSize.Y + delta.Y, minSize.Y, maxSize.Y)
                
                local changeW = newW - startSize.X
                local changeH = newH - startSize.Y
                
                frame.Size = UDim2.new(0, newW, 0, newH)
                frame.Position = UDim2.new(
                    startFramePos.X.Scale, startFramePos.X.Offset + changeW * 0.5,
                    startFramePos.Y.Scale, startFramePos.Y.Offset + changeH * 0.5
                )
            end
        end)
    end
end
