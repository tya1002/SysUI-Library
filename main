-- require
local SysUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/tya1002/SysUI-Library/main/loader?t=" .. os.time()))()

-- load
local Window = SysUI:Load()

-- Services
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local UserInputService = game:GetService("UserInputService")

-- Global States for Cheat Features
_G.WalkSpeedActive = false
_G.WalkSpeedVal = 16

_G.JumpPowerActive = false
_G.JumpPowerVal = 50

_G.InfJumpActive = false

_G.ESPActive = false
_G.ESPColor = Color3.fromRGB(0, 120, 255)

-- ==========================================
-- 🛠️ HACK LOOPS & CONNECTIONS
-- ==========================================

-- WalkSpeed & JumpPower loop
task.spawn(function()
    while task.wait(0.1) do
        pcall(function()
            local char = LocalPlayer.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if hum then
                if _G.WalkSpeedActive then
                    hum.WalkSpeed = _G.WalkSpeedVal
                else
                    hum.WalkSpeed = 16 -- restore default walkspeed if disabled
                end
                if _G.JumpPowerActive then
                    hum.UseJumpPower = true
                    hum.JumpPower = _G.JumpPowerVal
                else
                    hum.JumpPower = 50 -- restore default jumppower if disabled
                end
            end
        end)
    end
end)

-- Infinite Jump connection
UserInputService.JumpRequest:Connect(function()
    if _G.InfJumpActive then
        pcall(function()
            LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState(Enum.HumanoidStateType.Jumping)
        end)
    end
end)

-- ESP Highlight Logic
local espHighlights = {}

local function clearESP()
    for player, hl in pairs(espHighlights) do
        pcall(function() hl:Destroy() end)
    end
    table.clear(espHighlights)
end

local function applyESP(player)
    if player == LocalPlayer then return end
    
    local function setupChar(char)
        if not _G.ESPActive then return end
        
        -- Clear old highlight if exists
        if espHighlights[player] then
            pcall(function() espHighlights[player]:Destroy() end)
        end
        
        local hl = Instance.new("Highlight")
        hl.Name = "SysHubESP"
        hl.FillColor = _G.ESPColor
        hl.OutlineColor = Color3.fromRGB(255, 255, 255)
        hl.FillTransparency = 0.5
        hl.OutlineTransparency = 0
        hl.Adornee = char
        hl.Parent = char
        
        espHighlights[player] = hl
    end
    
    if player.Character then
        setupChar(player.Character)
    end
    player.CharacterAdded:Connect(setupChar)
end

local function updateESP()
    clearESP()
    if not _G.ESPActive then return end
    
    for _, player in ipairs(Players:GetPlayers()) do
        applyESP(player)
    end
end

Players.PlayerAdded:Connect(function(player)
    if _G.ESPActive then
        applyESP(player)
    end
end)

Players.PlayerRemoving:Connect(function(player)
    if espHighlights[player] then
        pcall(function() espHighlights[player]:Destroy() end)
        espHighlights[player] = nil
    end
end)


-- ==========================================
-- ⚔️ COMBAT TAB
-- ==========================================
local CombatTab = Window:CreateTab("Combat")

-- Aimbot Toggle dengan Keybind "E" terintegrasi dalam satu baris slot!
CombatTab:AddToggle("Aimbot Toggle", {
    Default = false,
    Keybind = Enum.KeyCode.E,
    Callback = function(enabled)
        print("Aimbot Toggle state changed to:", enabled)
    end,
    KeybindCallback = function()
        print("Aimbot Hotkey Triggered!")
    end
})

-- Slider FOV Range (Tanpa sub-toggle/keybind lain)
CombatTab:AddSlider("Aimbot FOV Range", {
    Min = 10,
    Max = 300,
    Default = 100,
    Unit = " studs",
    Callback = function(value)
        print("Aimbot FOV Radius set to:", value)
    end
})

-- Spinner Smoothness
CombatTab:AddSpinner("Aimbot Smoothness", {
    Min = 1,
    Max = 20,
    Default = 5,
    Step = 1,
    Callback = function(value)
        print("Aimbot Smoothness set to:", value)
    end
})

-- Input Target Player Name
