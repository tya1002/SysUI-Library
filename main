-- require
local SysUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/tya1002/SysUI-Library/main/loader?t=" .. os.time()))()

-- load
local Window = SysUI:Load()

-- ==========================================
-- ⚔️ COMBAT TAB
-- ==========================================
local CombatTab = Window:CreateTab("Combat")

-- Tambah Toggle Aimbot
CombatTab:AddToggle("Aimbot Toggle", false, function(enabled)
    print("Aimbot enabled:", enabled)
end)

-- Pasang Keybind to Aimbot Toggle
CombatTab:AddKeybind("Aimbot Toggle", Enum.KeyCode.E, function()
    print("Aimbot Hotkey Pressed!")
end)

-- Tambah Slider FOV Range
CombatTab:AddSlider("Aimbot FOV Range", 10, 300, 100, " studs", function(value)
    print("Aimbot FOV set to:", value)
end)

-- Tambah Spinner Smoothness
CombatTab:AddSpinner("Aimbot Smoothness", 1, 20, 5, 1, function(value)
    print("Aimbot Smoothness set to:", value)
end)

-- Tambah Input Target Player
CombatTab:AddInput("Target Player Name", "Enter username...", function(text)
    print("Target Player set to:", text)
end)

-- Tambah Toggle Team Check
CombatTab:AddToggle("Team Check", true, function(enabled)
    print("Team Check state:", enabled)
end)


-- ==========================================
-- 👁️ VISUALS TAB
-- ==========================================
local VisualsTab = Window:CreateTab("Visuals")

-- Tambah Dropdown ESP Type
VisualsTab:AddDropdown("ESP Type", {"Box", "Chams", "Tracers", "Disabled"}, "Disabled", function(choice)
    print("ESP Type set to:", choice)
end)

-- Tambah Toggle ESP Name Tags
VisualsTab:AddToggle("ESP Name Tags", false, function(enabled)
    print("ESP Name Tags state:", enabled)
end)

-- Tambah Slider Tracers Transparency
VisualsTab:AddSlider("Tracers Transparency", 0, 100, 50, "%", function(val)
    print("Tracers Transparency set to:", val)
end)

-- Tambah Colorpicker Box Color
VisualsTab:AddColorpicker("ESP Box Color", Color3.fromRGB(0, 120, 255), function(color)
    print("ESP Box Color updated:", tostring(color))
end)

-- Tambah Spinner Max ESP Distance
VisualsTab:AddSpinner("Max ESP Distance", 50, 2000, 500, 50, function(value)
    print("Max ESP Distance set to:", value)
end)

-- Tambah Button Force Reload ESP
VisualsTab:AddButton("Force Reload ESP", function()
    print("ESP reloaded successfully!")
    SysUI:Notify({
        Title = "Visuals System",
        Content = "ESP modules reloaded!",
        Duration = 2.5
    })
end)


-- ==========================================
-- ⚙️ MISC TAB
-- ==========================================
local MiscTab = Window:CreateTab("Misc")

-- Tambah Slider WalkSpeed Hack
MiscTab:AddSlider("WalkSpeed Hack", 16, 200, 16, " studs/s", function(val)
    print("WalkSpeed Multiplier set to:", val)
end)

-- Tambah Dropdown Teleport Player
MiscTab:AddDropdown("Teleport Player", {"Select Player", "Sugeng", "Budi", "Tono"}, "Select Player", function(choice)
    print("Teleport requested to player:", choice)
end)

-- Tambah Colorpicker Accent Color
MiscTab:AddColorpicker("Accent Color", Color3.fromRGB(0, 85, 255), function(color)
    print("UI Accent Color customized:", tostring(color))
end)

-- Tambah Slider JumpPower Hack
MiscTab:AddSlider("JumpPower Hack", 50, 300, 50, " power", function(val)
    print("JumpPower Multiplier set to:", val)
end)

-- Tambah Spinner Gravity Changer
MiscTab:AddSpinner("Gravity Changer", 0, 196, 196, 10, function(val)
    print("Gravity changed to:", val)
end)

-- Tambah Toggle Infinite Jump
MiscTab:AddToggle("Infinite Jump", false, function(enabled)
    print("Infinite Jump state:", enabled)
end)

-- Tambah Input Console Command
MiscTab:AddInput("Console Command", "/command...", function(text)
    print("Console command submitted:", text)
end)

-- Tambah Button Uninstall Script
MiscTab:AddButton("Uninstall Script", function()
    print("Destructing UI...")
    Window:GetGui():Destroy()
    SysUI:Notify({
        Title = "SysHub",
        Content = "UI has been successfully uninstalled!",
        Duration = 3
    })
end)


-- Hook Config Actions
Window:BindConfigActions({
    OnLoad = function()
        print("Configuration Profile Loaded successfully!")
    end,
    OnSave = function()
        print("Configuration Profile Saved successfully!")
    end
})


-- Notify loading
SysUI:Notify({
    Title = "SysHub Loaded",
    Content = "All features are active! Press RightShift to hide.",
    Duration = 4
})
