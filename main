CombatTab:AddDropdown("Target Hitbox", {
    Options = {"Head", "Torso", "HumanoidRootPart", "Random"},
    Default = "Head",
    Callback = function(choice)
        print("Aimbot Target Hitbox selected:", choice)
    end
})

-- Toggle Team Check
CombatTab:AddToggle("Team Check", {
    Default = true,
    Callback = function(enabled)
        print("Team Check state changed to:", enabled)
    end
})


-- ==========================================
-- 👁️ VISUALS TAB
-- ==========================================
local VisualsTab = Window:CreateTab("Visuals")

-- Dropdown ESP Type (Fully Functional)
VisualsTab:AddDropdown("ESP Type", {
    Options = {"Enabled", "Disabled"},
    Default = "Disabled",
    Callback = function(choice)
        _G.ESPActive = (choice == "Enabled")
        updateESP()
        print("ESP Status set to:", choice)
    end
})

-- ESP Name Tags Toggle
VisualsTab:AddToggle("ESP Name Tags", {
    Default = false,
    Callback = function(enabled)
        print("ESP Name Tags state:", enabled)
    end
})

-- Slider Tracers Transparency
VisualsTab:AddSlider("Tracers Transparency", {
    Min = 0,
    Max = 100,
    Default = 50,
    Unit = "%",
    Callback = function(val)
        print("Tracers transparency set to:", val)
    end
})

-- Colorpicker ESP Box Color (Fully Functional)
VisualsTab:AddColorpicker("ESP Box Color", {
    Default = Color3.fromRGB(0, 120, 255),
    Callback = function(color)
        _G.ESPColor = color
        -- Update colors of all active highlights dynamically
        for player, hl in pairs(espHighlights) do
            pcall(function() hl.FillColor = color end)
        end
        print("ESP color changed:", tostring(color))
    end
})

-- Spinner Max ESP Distance
VisualsTab:AddSpinner("Max ESP Distance", {
    Min = 50,
    Max = 2000,
    Default = 500,
    Step = 50,
    Callback = function(value)
        print("Max ESP Distance set to:", value)
    end
})

-- Button Force Reload ESP (Fully Functional)
VisualsTab:AddButton("Force Reload ESP", {
    Callback = function()
        updateESP()
        SysUI:Notify({
            Title = "Visuals System",
            Content = "ESP highlights reloaded!",
            Duration = 2
        })
    end
})


