    Name = "Accent Color",
    Default = Color3.fromRGB(0, 85, 255),
    Callback = function(color)
        print("UI Accent Color customized:", tostring(color))
    end
})

-- Row_D: Slider
Window:BindSlider("Page_1_C", "Row_D", {
    Name = "JumpPower Hack",
    Min = 50,
    Max = 300,
    Default = 50,
    Unit = " power",
    Callback = function(val)
        print("JumpPower Multiplier set to:", val)
    end
})

-- Row_E: Spinner
Window:BindSpinner("Page_1_C", "Row_E", {
    Name = "Gravity Changer",
